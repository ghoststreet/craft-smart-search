{% extends "_layouts/cp" %}
{% import 'smart-search/_components/filter-fields' as f %}

{% set title = 'Insights' %}
{% set selectedSubnavItem = 'insights' %}

{% set days = filters.days %}
{% set siteId = filters.siteId %}
{% set tabParams = { days: days, siteId: siteId } %}

{% set tabs = {
    queries:        { label: 'Top queries',  url: cpUrl('smart-search/insights', tabParams|merge({ tab: 'queries' })) },
    'zero-results': { label: 'Zero results', url: cpUrl('smart-search/insights', tabParams|merge({ tab: 'zero-results' })) },
    trending:       { label: 'Trending',     url: cpUrl('smart-search/insights', tabParams|merge({ tab: 'trending' })) },
    history:        { label: 'History log',  url: cpUrl('smart-search/insights', tabParams|merge({ tab: 'history' })) },
} %}
{% set selectedTab = tab %}

{% block content %}
    {% if tab == 'history' %}
        <div class="kpi-grid kpi-grid--compact">
            <div class="kpi-card kpi-card--compact">
                <span class="cp-icon kpi-card__icon">{{ iconSvg('magnifying-glass') }}</span>
                <div class="kpi-card__body">
                    <div class="kpi-card__label">Searches</div>
                    <div class="kpi-card__value">{{ stats.searches|number_format }}</div>
                </div>
            </div>
            <div class="kpi-card kpi-card--compact">
                <span class="cp-icon kpi-card__icon">{{ iconSvg('hashtag') }}</span>
                <div class="kpi-card__body">
                    <div class="kpi-card__label">Tokens</div>
                    <div class="kpi-card__value">{{ stats.tokens|number_format }}</div>
                </div>
            </div>
            <div class="kpi-card kpi-card--compact">
                <span class="cp-icon kpi-card__icon">{{ iconSvg('coin') }}</span>
                <div class="kpi-card__body">
                    <div class="kpi-card__label">Total cost</div>
                    <div class="kpi-card__value">${{ stats.cost|number_format(6) }}</div>
                </div>
            </div>
            <div class="kpi-card kpi-card--compact">
                <span class="cp-icon kpi-card__icon">{{ iconSvg('gauge-high') }}</span>
                <div class="kpi-card__body">
                    <div class="kpi-card__label">Avg duration</div>
                    <div class="kpi-card__value">{{ stats.avgDurationMs|number_format }}<span class="kpi-card__value-unit"> ms</span></div>
                </div>
            </div>
            <div class="kpi-card kpi-card--compact{% if stats.errorCount > 0 %} kpi-card--error{% endif %}">
                <span class="cp-icon kpi-card__icon">{{ iconSvg('triangle-exclamation') }}</span>
                <div class="kpi-card__body">
                    <div class="kpi-card__label">Errors</div>
                    <div class="kpi-card__value{% if stats.errorCount > 0 %} kpi-card__error{% endif %}">{{ stats.errorCount|number_format }}</div>
                </div>
            </div>
        </div>
    {% endif %}

    <div class="filter-bar">
        <form method="get" action="{{ cpUrl('smart-search/insights') }}" class="filter-bar__form">
            <input type="hidden" name="tab" value="{{ tab }}">
            <div class="filter-bar__group">
                {{ f.daysSelect(days, 'Time range') }}
                {{ f.sitesSelect(sites, siteId) }}
                {% if tab == 'history' %}
                    {{ f.typeSelect(filters.type) }}
                    {{ f.errorsOnlyCheckbox(filters.errorsOnly, true) }}
                {% endif %}
                {{ f.submitButton() }}
            </div>
        </form>
        {% if tab == 'history' and currentUser.admin %}
            <form method="post" class="filter-bar__spacer" data-craftsearch-confirm="Permanently delete all stored queries and result data? Token/cost statistics are preserved.">
                {{ csrfInput() }}
                {{ actionInput('smart-search/insights/clear') }}
                <button type="submit" class="btn" data-icon="trash"{% if detailsCount == 0 %} disabled{% endif %}>Clear history ({{ detailsCount }})</button>
            </form>
        {% endif %}
    </div>

    {% if tab == 'queries' %}
        <p class="light">Your 30 most-searched queries for the selected period. Use it to see what your audience wants and to spot popular searches returning few or no results.</p>
        {% if topQueries|length %}
            <div class="tableview data-table data-table--auto">
                <table class="data fullwidth big">
                    <thead>
                        <tr>
                            <th scope="col">Query</th>
                            <th scope="col" class="rightalign">Searches</th>
                            <th scope="col" class="rightalign">Avg results</th>
                            <th scope="col">Last searched</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for k in topQueries %}
                            {% set sharePct = totalSearches > 0 ? (k.hits / totalSearches * 100)|round : 0 %}
                            <tr>
                                <td>{{ k.query|slice(0, 100) }}{% if k.query|length > 100 %}…{% endif %}</td>
                                <td class="rightalign">{{ k.hits|number_format }} <span class="light">({{ sharePct }}%)</span></td>
                                <td class="rightalign">
                                    {% if k.avgResults < 1 %}<span class="status orange" title="Returns few or no results"></span> {% endif %}
                                    <span class="light">{{ k.avgResults|number_format(1) }}</span>
                                </td>
                                <td><span class="light" title="{{ k.lastSeen|date('Y-m-d H:i:s') }}">{{ k.lastSeen|date('M j, g:ia') }}</span></td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <div class="zilch small">No queries recorded.</div>
        {% endif %}

    {% elseif tab == 'zero-results' %}
        <p class="light">Queries that returned no results. These often reveal missing content or overly strict thresholds.</p>
        {% if page.items|length %}
            <div class="tableview data-table data-table--auto">
                <table class="data fullwidth big">
                    <thead>
                        <tr>
                            <th scope="col">Query</th>
                            <th scope="col" class="rightalign">Hits</th>
                            <th scope="col" class="rightalign">Avg time</th>
                            <th scope="col" class="rightalign">Errors</th>
                            <th scope="col">Last searched</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for k in page.items %}
                            <tr>
                                <td>{{ k.query|slice(0, 100) }}{% if k.query|length > 100 %}…{% endif %}</td>
                                <td class="rightalign">{{ k.hits|number_format }}</td>
                                <td class="rightalign light">{{ k.avgDurationMs|round }} ms</td>
                                <td class="rightalign">
                                    {% if k.errors > 0 %}<span class="status red"></span> {{ k.errors }}{% else %}—{% endif %}
                                </td>
                                <td><span class="light" title="{{ k.lastSeen|date('Y-m-d H:i:s') }}">{{ k.lastSeen|date('M j, g:ia') }}</span></td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <div class="zilch small">All searches returned results.</div>
        {% endif %}

        {% include 'smart-search/_components/pagination-cp' with {
            currentPage: page.page,
            totalPages: page.pages,
            path: 'smart-search/insights',
            baseParams: { tab: 'zero-results', days: days, siteId: siteId },
        } only %}

    {% elseif tab == 'trending' %}
        <p class="light">Queries whose frequency rose in the last 7 days vs the prior 7-day window.</p>
        {% if page.items|length %}
            <div class="tableview data-table data-table--auto">
                <table class="data fullwidth big">
                    <thead>
                        <tr>
                            <th scope="col">Query</th>
                            <th scope="col" class="rightalign">Recent</th>
                            <th scope="col" class="rightalign">Prior</th>
                            <th scope="col" class="rightalign">Δ</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for k in page.items %}
                            <tr>
                                <td>{{ k.query|slice(0, 100) }}{% if k.query|length > 100 %}…{% endif %}</td>
                                <td class="rightalign">{{ k.recent }}</td>
                                <td class="rightalign">{{ k.prior }}</td>
                                <td class="rightalign">
                                    {% if k.growthPct is null %}<span class="status on" title="New"></span> new
                                    {% else %}+{{ k.growthPct }}%{% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <div class="zilch small">Not enough data to spot trends.</div>
        {% endif %}

        {% include 'smart-search/_components/pagination-cp' with {
            currentPage: page.page,
            totalPages: page.pages,
            path: 'smart-search/insights',
            baseParams: { tab: 'trending', days: days, siteId: siteId },
        } only %}

    {% elseif tab == 'history' %}
        {% include 'smart-search/_partials/search-history-table' with {
            items: page.items,
            urlPath: 'smart-search/insights',
            cachedTitle: 'Cached',
        } only %}

        {% include 'smart-search/_components/pagination-cp' with {
            currentPage: page.page,
            totalPages: page.pages,
            path: 'smart-search/insights',
            baseParams: { tab: 'history', days: days, siteId: siteId, type: filters.type, errorsOnly: filters.errorsOnly ? 1 : null },
        } only %}
    {% endif %}
{% endblock %}
