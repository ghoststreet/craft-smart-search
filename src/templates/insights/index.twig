{% set pageKey = 'overview' %}
{% set pageUrl = cpUrl('smart-search/insights') %}
{% set showDays = true %}
{% set showType = true %}
{% set showErrorsOnly = stats.errorCount > 0 %}
{% set hasResults = page.items|length > 0 %}

{% extends 'smart-search/insights/_layout' %}

{% block kpis %}
    <div class="ss-kpi-grid ss-kpi-grid--compact">
        {% for c in [
            { icon: 'magnifying-glass', label: 'Searches',         value: stats.searches|number_format },
            { icon: 'hashtag',          label: 'Embedding tokens', value: stats.embeddingTokens|number_format },
            { icon: 'robot',            label: 'LLM tokens',       value: stats.llmTokens|number_format },
            { icon: 'coin',             label: 'Total cost',       value: '$' ~ stats.cost|number_format(6) },
            { icon: 'gauge-high',       label: 'Avg duration',     value: stats.avgDurationMs|number_format, unit: ' ms' },
        ] %}
            <div class="ss-kpi-card ss-kpi-card--compact">
                <span class="cp-icon ss-kpi-card__icon">{{ iconSvg(c.icon) }}</span>
                <div class="ss-kpi-card__body">
                    <div class="ss-kpi-card__label">{{ c.label }}</div>
                    <div class="ss-kpi-card__value">{{ c.value }}{% if c.unit is defined %}<span class="ss-kpi-card__value-unit">{{ c.unit }}</span>{% endif %}</div>
                </div>
            </div>
        {% endfor %}
        {% if stats.errorCount > 0 %}
            <a href="{{ cpUrl('smart-search/insights', { errorsOnly: 1, days: filters.days, siteId: filters.siteId }) }}"
               class="ss-kpi-card ss-kpi-card--compact ss-kpi-card--error ss-kpi-card--link" title="View errored searches">
                <span class="cp-icon ss-kpi-card__icon">{{ iconSvg('triangle-exclamation') }}</span>
                <div class="ss-kpi-card__body">
                    <div class="ss-kpi-card__label">Errors</div>
                    <div class="ss-kpi-card__value ss-kpi-card__error">{{ stats.errorCount|number_format }}</div>
                </div>
            </a>
        {% endif %}
    </div>
{% endblock %}

{% block insightsContent %}
    {% include 'smart-search/_partials/search-history-table' with { items: page.items } only %}

    {% include 'smart-search/_components/pagination' with {
        currentPage: page.page,
        totalPages: page.pages,
        path: 'smart-search/insights',
        params: { days: filters.days, siteId: filters.siteId, type: filters.type, errorsOnly: filters.errorsOnly ? 1 : null },
    } only %}
{% endblock %}
