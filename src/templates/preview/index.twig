{% extends "_layouts/cp" %}

{% set title = 'Preview' %}
{% set selectedSubnavItem = 'preview' %}

{% block content %}
<div data-craftsearch-target="preview-page">

    {% if sites|length > 1 %}
        <div class="toolbar">
            <div class="flex">
                <label for="preview-site" class="visually-hidden">Site</label>
                <div class="select">
                    <select id="preview-site" data-craftsearch-control="site-select">
                        {% for site in sites %}
                            <option value="{{ site.id }}"{% if site.id == craft.app.sites.currentSite.id %} selected{% endif %}>
                                {{ site.name }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
            </div>
        </div>
    {% endif %}

    <div class="preview-info pane">
        <div class="preview-info__content">
            <h2>Test your search setup</h2>
            <p>Use this page to run live queries against all three search modes side-by-side. <br> Each mode maps to a different API endpoint you can call from your front end.</p>
        </div>
        <table>
            <thead>
                <tr>
                    <th>Endpoint</th>
                    <th>Method</th>
                    <th><code>type</code></th>
                    <th>Description</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><code>/actions/smart-search/search</code></td>
                    <td>POST</td>
                    <td><code>search</code></td>
                    <td>Semantic vector + keyword</td>
                </tr>
                <tr>
                    <td><code>/actions/smart-search/search</code></td>
                    <td>POST</td>
                    <td><code>ai-answer</code></td>
                    <td>AI Answer with citations</td>
                </tr>
                <tr>
                    <td><code>/actions/smart-search/search</code></td>
                    <td>GET (SSE)</td>
                    <td><code>ai-answer-stream</code></td>
                    <td>Streaming version of AI Answer</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="preview-grid">

        <div class="preview-col">
            <div class="pane preview-col__pane">
                <h2 class="preview-col__heading">Smart Search <span class="preview-badge preview-badge--smart">Semantic + Keyword</span></h2>
                <p class="preview-col__desc">Combines semantic (vector) similarity with keyword scoring for the most relevant results.</p>
                <div class="preview-col__form">
                    <input type="search" class="text" placeholder="Search…" autocomplete="off"
                           data-craftsearch-control="smart-input">
                    <button class="btn" data-craftsearch-control="smart-submit" aria-label="Search">
                        <span data-icon="search" aria-hidden="true"></span>
                    </button>
                </div>
                <div class="preview-col__results" data-craftsearch-target="smart-results" role="region" hidden></div>
                <div class="preview-col__error" data-craftsearch-target="smart-error" role="alert" hidden></div>
            </div>
        </div>

        <div class="preview-col">
            <div class="pane preview-col__pane">
                <h2 class="preview-col__heading">AI Answer <span class="preview-badge preview-badge--ai-answer">Generated</span></h2>
                <p class="preview-col__desc">Retrieves matching entries then generates a streaming AI summary with inline citations.</p>
                <div class="preview-col__form">
                    <input type="search" class="text" placeholder="Search…" autocomplete="off"
                           data-craftsearch-control="ai-answer-input">
                    <button class="btn" data-craftsearch-control="ai-answer-submit" aria-label="Search">
                        <span data-icon="search" aria-hidden="true"></span>
                    </button>
                </div>
                <div class="preview-col__summary" data-craftsearch-target="ai-answer-summary" hidden></div>
                <div class="preview-col__results" data-craftsearch-target="ai-answer-results" role="region" hidden></div>
                <div class="preview-col__error" data-craftsearch-target="ai-answer-error" role="alert" hidden></div>
            </div>
        </div>

    </div>

    <template data-craftsearch-target="loading-tpl">
        <div class="preview-col__loading">
            <span class="preview-col__loading-spinner"></span>
            Searching…
        </div>
    </template>

    <template data-craftsearch-target="cite-tpl">
        <a class="preview-col__cite" href="" target="_blank" rel="noopener" data-craftsearch-target="field-url"></a>
    </template>

    <template data-craftsearch-target="result-card-tpl">
        <div class="preview-result-card" data-craftsearch-target="result-card">
            <a class="preview-result-card__title" href="" target="_blank" rel="noopener" data-craftsearch-target="field-url"></a>
            <p class="preview-result-card__excerpt" data-craftsearch-target="field-excerpt"></p>
        </div>
    </template>

</div>
{% endblock %}
