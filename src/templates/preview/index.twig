{% extends "_layouts/cp" %}

{% set title = 'Preview' %}
{% set selectedSubnavItem = 'preview' %}

{% block content %}
<div data-craftsearch-target="preview-page"
     data-craftsearch-config="{{ {
         csrfTokenName: craft.app.config.general.csrfTokenName,
         csrfTokenValue: craft.app.request.csrfToken,
         siteId: craft.app.sites.currentSite.id,
     }|json_encode }}">

    {% if sites|length > 1 %}
        <div class="toolbar">
            <div class="flex">
                <label for="preview-site" class="visually-hidden">Site</label>
                <div class="select">
                    <select id="preview-site" data-craftsearch-control="site-select">
                        {% for site in sites %}
                            <option value="{{ site.id }}"{% if site.id == craft.app.sites.currentSite.id %} selected{% endif %}>
                                {{ site.name }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
            </div>
        </div>
    {% endif %}

    <div class="preview-info pane">
        <div class="preview-info__content">
            <h2>Test your search setup</h2>
            <p>Use this page to run live queries against all three search modes side-by-side. <br> Each mode maps to a different API endpoint you can call from your front end.</p>
        </div>
        <table>
            <thead>
                <tr>
                    <th>Endpoint</th>
                    <th>Method</th>
                    <th>Description</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><code>/api/hybrid-search</code></td>
                    <td>POST</td>
                    <td>Semantic vector + BM25 keyword</td>
                </tr>
                <tr>
                    <td><code>/api/rag-search</code></td>
                    <td>POST</td>
                    <td>AI-generated summary with citations</td>
                </tr>
                <tr>
                    <td><code>/api/rag-search/stream</code></td>
                    <td>GET (SSE)</td>
                    <td>Streaming version of RAG</td>
                </tr>
                <tr>
                    <td><code>/api/craft-search</code></td>
                    <td>POST</td>
                    <td>Craft native full-text search</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="preview-grid">

        <div class="preview-col">
            <div class="pane preview-col__pane">
                <h2 class="preview-col__heading">Hybrid Search <span class="preview-badge preview-badge--hybrid">Semantic + BM25</span></h2>
                <p class="preview-col__desc">Combines semantic (vector) similarity with BM25 keyword scoring for the most relevant results.</p>
                <div class="preview-col__form">
                    <input type="search" class="text" placeholder="Search…" autocomplete="off"
                           data-craftsearch-control="hybrid-input">
                    <button class="btn" data-craftsearch-control="hybrid-submit" aria-label="Search">
                        <span data-icon="search" aria-hidden="true"></span>
                    </button>
                </div>
                <div class="preview-col__results" data-craftsearch-target="hybrid-results" role="region" hidden></div>
                <div class="preview-col__error" data-craftsearch-target="hybrid-error" role="alert" hidden></div>
            </div>
        </div>

        <div class="preview-col">
            <div class="pane preview-col__pane">
                <h2 class="preview-col__heading">RAG Search <span class="preview-badge preview-badge--rag">AI Summary</span></h2>
                <p class="preview-col__desc">Retrieves matching entries then generates a streaming AI summary with inline citations.</p>
                <div class="preview-col__form">
                    <input type="search" class="text" placeholder="Search…" autocomplete="off"
                           data-craftsearch-control="rag-input">
                    <button class="btn" data-craftsearch-control="rag-submit" aria-label="Search">
                        <span data-icon="search" aria-hidden="true"></span>
                    </button>
                </div>
                <div class="preview-col__summary" data-craftsearch-target="rag-summary" hidden></div>
                <div class="preview-col__results" data-craftsearch-target="rag-results" role="region" hidden></div>
                <div class="preview-col__error" data-craftsearch-target="rag-error" role="alert" hidden></div>
            </div>
        </div>

        <div class="preview-col">
            <div class="pane preview-col__pane">
                <h2 class="preview-col__heading">Craft Search <span class="preview-badge preview-badge--craft">Native</span></h2>
                <p class="preview-col__desc">Runs Craft's built-in full-text search — useful as a baseline comparison.</p>
                <div class="preview-col__form">
                    <input type="search" class="text" placeholder="Search…" autocomplete="off"
                           data-craftsearch-control="craft-input">
                    <button class="btn" data-craftsearch-control="craft-submit" aria-label="Search">
                        <span data-icon="search" aria-hidden="true"></span>
                    </button>
                </div>
                <div class="preview-col__results" data-craftsearch-target="craft-results" role="region" hidden></div>
                <div class="preview-col__error" data-craftsearch-target="craft-error" role="alert" hidden></div>
            </div>
        </div>

    </div>

    <template data-craftsearch-target="loading-tpl">
        <div class="preview-col__loading">
            <span class="preview-col__loading-spinner"></span>
            Searching…
        </div>
    </template>

    <template data-craftsearch-target="cite-tpl">
        <a class="preview-col__cite" href="" target="_blank" rel="noopener" data-field="url"></a>
    </template>

    <template data-craftsearch-target="result-card-tpl">
        <div class="preview-result-card">
            <a class="preview-result-card__title" href="" target="_blank" rel="noopener" data-field="url"></a>
            <p class="preview-result-card__excerpt" data-field="excerpt"></p>
        </div>
    </template>

</div>
{% endblock %}
