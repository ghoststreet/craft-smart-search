{% extends "_layouts/cp" %}

{% set title = 'Preview' %}
{% set selectedSubnavItem = 'preview' %}

{% block content %}
<div data-craftsearch-target="preview-page">

    {% if sites|length > 1 %}
        <div class="toolbar">
            <div class="flex">
                <label for="preview-site" class="visually-hidden">Site</label>
                <div class="select">
                    <select id="preview-site" data-craftsearch-control="site-select">
                        {% for site in sites %}
                            <option value="{{ site.id }}"{% if site.id == craft.app.sites.currentSite.id %} selected{% endif %}>
                                {{ site.name }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
            </div>
        </div>
    {% endif %}

    <div class="ss-preview-info pane">
        <div class="ss-preview-info__content">
            <h2>Test your search setup</h2>
            <p>
                Run live queries against each search mode side-by-side. Every mode maps to an endpoint you
                can call from your front end — see
                <a href="{{ wikiUrl }}/Using-the-API" target="_blank" rel="noopener">Using the API</a>
                for the request and response shapes.
            </p>
        </div>
    </div>

    <div class="ss-preview-grid">

        {# `key` drives the badge modifier and every data-craftsearch-* name (see pages/preview.js). #}
        {% for c in [
            { key: 'smart', title: 'Smart Search', badge: 'Semantic + Keyword',
              desc: 'Combines semantic (vector) similarity with keyword scoring for the most relevant results.' },
            { key: 'ai-answer', title: 'AI Answer', badge: 'Generated', summary: true,
              desc: 'Retrieves matching entries then generates a streaming AI summary with inline citations.' },
        ] %}
            <div class="ss-preview-col">
                <div class="pane ss-preview-col__pane">
                    <h2 class="ss-preview-col__heading">{{ c.title }} <span class="ss-preview-badge ss-preview-badge--{{ c.key }}">{{ c.badge }}</span></h2>
                    <p class="ss-preview-col__desc">{{ c.desc }}</p>
                    <div class="ss-preview-col__form">
                        <input type="search" class="text" placeholder="Search…" autocomplete="off"
                               data-craftsearch-control="{{ c.key }}-input">
                        <button class="btn" data-craftsearch-control="{{ c.key }}-submit" aria-label="Search">
                            <span data-icon="search" aria-hidden="true"></span>
                        </button>
                    </div>
                    {% if c.summary is defined %}
                        <div class="ss-preview-col__summary" data-craftsearch-target="{{ c.key }}-summary" hidden></div>
                    {% endif %}
                    <div class="ss-preview-col__results" data-craftsearch-target="{{ c.key }}-results" role="region" hidden></div>
                    <div class="ss-preview-col__error" data-craftsearch-target="{{ c.key }}-error" role="alert" hidden></div>
                </div>
            </div>
        {% endfor %}

    </div>

    <template data-craftsearch-target="loading-tpl">
        <div class="ss-preview-col__loading">
            <span class="ss-preview-col__loading-spinner"></span>
            Searching…
        </div>
    </template>

    <template data-craftsearch-target="cite-tpl">
        <a class="ss-preview-col__cite" href="" target="_blank" rel="noopener" data-craftsearch-target="field-url"></a>
    </template>

    <template data-craftsearch-target="result-card-tpl">
        <div class="ss-preview-result-card" data-craftsearch-target="result-card">
            <a class="ss-preview-result-card__title" href="" target="_blank" rel="noopener" data-craftsearch-target="field-url"></a>
            <p class="ss-preview-result-card__excerpt" data-craftsearch-target="field-excerpt"></p>
        </div>
    </template>

</div>
{% endblock %}
