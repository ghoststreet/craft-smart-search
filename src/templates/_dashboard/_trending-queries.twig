{#
    Trending queries card — keywords whose volume rose vs the prior window.

    Params:
        trendingQueries  iterable of { query, recent, prior, delta, growthPct? }
#}
<div class="pane">
    <h3 class="ss-dash-title">Trending queries</h3>
    <p class="ss-dash-sub light smalltext">Biggest growth vs the prior period.</p>
    <table class="data fullwidth">
        <thead>
            <tr>
                <th>Query</th>
                <th class="rightalign">Recent</th>
                <th class="rightalign">Growth</th>
            </tr>
        </thead>
        <tbody>
            {% for q in trendingQueries %}
                <tr>
                    <td>{{ q.query|truncate(80) }}</td>
                    <td class="rightalign">{{ q.recent|number_format }}</td>
                    <td class="rightalign">
                        <span class="ss-delta-tag ss-delta-tag--up">{{ q.growthPct is null ? 'new' : '▲ ' ~ q.growthPct ~ '%' }}</span>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="3" class="centeralign light">No trending queries detected — search volume is stable.</td></tr>
            {% endfor %}
        </tbody>
    </table>
    {% if trendingQueries|length %}
        <p class="ss-dash-cta"><a class="go" href="{{ cpUrl('smart-search/insights/trending') }}">View all trending</a></p>
    {% endif %}
</div>
