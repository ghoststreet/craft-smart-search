{#
    Onboarding card shown on the dashboard until required setup is complete.

    Params:
        settings           Plugin settings model
        stats              { isConnected, entryCount }
        requiredSteps      list<{ done, label, hint, cta: { url, label } }>
        recommendedSteps   list<{ done, label, hint, cta: { url, label } }>
#}
<div class="pane onboarding-card">
    <div class="onboarding-card__intro">
        <div class="onboarding-card__icon" aria-hidden="true">
            {{ svg('@ghoststreet/craftsmartsearch/icon.svg') }}
        </div>
        <div class="onboarding-card__intro-body">
            <h2 class="dash-lede">Welcome to Smart Search</h2>
            <p class="light dash-lede">
                Smart Search adds semantic search to your Craft site, so visitors get results based on what
                they meant rather than just what they typed, with typo tolerance and multi-language stemming
                handled for you. You can also turn on AI Answer to show a short cited summary written from
                your own entries. The checklist below covers the three connections needed to turn it on, plus
                two optional settings for AI Answer.
            </p>
        </div>
    </div>

    <h3 class="onboarding-section">1. Connect the services search runs on</h3>
    <p class="light onboarding-section__hint">
        Smart Search stores a vector for every entry and asks an AI model to read them at query time.
        These three steps wire up that storage, that model, and the first batch of vectors.
    </p>
    <ol class="onboarding-list">
        {% for s in requiredSteps %}
            <li class="onboarding-list__item{% if s.done %} onboarding-list__item--done{% endif %}{% if s.disabled ?? false %} onboarding-list__item--disabled{% endif %}">
                <span class="onboarding-list__icon">
                    {% if s.done %}<span data-icon="check"></span>{% else %}{{ loop.index }}{% endif %}
                </span>
                <div class="onboarding-list__body">
                    <strong>{{ s.label }}</strong>
                    <div class="light">{{ s.hint }}</div>
                </div>
                {% if not s.done %}
                    {% if s.disabled ?? false %}
                        <span class="btn submit disabled" aria-disabled="true">{{ s.cta.label }}</span>
                    {% else %}
                        <a class="btn submit" href="{{ s.cta.url }}">{{ s.cta.label }}</a>
                    {% endif %}
                {% endif %}
            </li>
        {% endfor %}
    </ol>

    {% if recommendedSteps|length %}
        <h3 class="onboarding-section onboarding-section--muted">2. Tailor it to your site</h3>
        <p class="light onboarding-section__hint">
            Search will work without these, but they’re the two settings most teams want to change
            before going live. They control how the AI Answer sounds and how much it’s allowed to spend.
        </p>
        <ol class="onboarding-list onboarding-list--recommended">
            {% for s in recommendedSteps %}
                <li class="onboarding-list__item{% if s.done %} onboarding-list__item--done{% endif %}">
                    <span class="onboarding-list__icon">
                        {% if s.done %}<span data-icon="check"></span>{% endif %}
                    </span>
                    <div class="onboarding-list__body">
                        <strong>{{ s.label }}</strong>
                        <div class="light">{{ s.hint }}</div>
                    </div>
                    {% if not s.done %}
                        <a class="btn" href="{{ s.cta.url }}">{{ s.cta.label }}</a>
                    {% endif %}
                </li>
            {% endfor %}
        </ol>
    {% endif %}
</div>
