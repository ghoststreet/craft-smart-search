{#
    Recommendations card for a single severity level.
    Crit items are surfaced as a page-top banner by index.twig, so they never reach here.

    Params:
        recommendations  iterable of { level, title, body, cta? }
        level            'warn' | 'info'
        heading          string  card title
#}
{% set items = recommendations|filter(r => r.level == level) %}

{% if items|length %}
    <div class="pane ss-recommendation-list">
        <h3 class="ss-dash-title">{{ heading }}</h3>
        <ul class="ss-recommendation-list__items">
            {% for r in items %}
                <li>
                    <span class="ss-recommendation-list__level ss-recommendation-list__level--{{ r.level }}">{{ r.levelLabel }}</span>
                    <strong>{{ r.title }}.</strong>
                    <span class="ss-recommendation-list__body">{{ r.body }}</span>
                    {% if r.cta %}<a class="ss-recommendation-list__cta" href="{{ r.cta.url }}">{{ r.cta.label }} →</a>{% endif %}
                </li>
            {% endfor %}
        </ul>
    </div>
{% endif %}
