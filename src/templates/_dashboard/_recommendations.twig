{#
    Recommendations card for a single severity level.
    Crit items are surfaced as a page-top banner by index.twig, so they never reach here.

    Params:
        recommendations  iterable of { level, title, body, cta? }
        level            'warn' | 'info'
        heading          string  card title
#}
{% set items = recommendations|filter(r => r.level == level) %}

{% if items|length %}
    <div class="pane recommendation-list">
        <h3 class="dash-title">{{ heading }}</h3>
        <ul class="recommendation-list__items">
            {% for r in items %}
                <li>
                    <span class="recommendation-list__level recommendation-list__level--{{ r.level }}">{{ { warn: 'Warning', info: 'Tip' }[r.level] ?? r.level }}</span>
                    <strong>{{ r.title }}.</strong>
                    <span class="recommendation-list__body">{{ r.body }}</span>
                    {% if r.cta %}<a class="recommendation-list__cta" href="{{ r.cta.url }}">{{ r.cta.label }} →</a>{% endif %}
                </li>
            {% endfor %}
        </ul>
    </div>
{% endif %}
