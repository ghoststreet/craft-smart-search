{#
    Advanced tab body — admin/ops focused.
#}
{% include 'smart-search/_dashboard/_kpi-ops' with {
    aggregates: aggregates,
    seriesCost: seriesCost,
    seriesDuration: seriesDuration,
    budget: budget,
    budgetClass: budgetClass,
    budgetPct: budgetPct,
    stats: stats,
    coveragePct: coveragePct,
    daysWithData: daysWithData,
    minNRate: minNRate,
    minNDelta: minNDelta,
    minDaysBudgetEta: minDaysBudgetEta,
} only %}

<div class="dashboard__cols">
    <div class="pane">
        <h3 class="dash-title">Coverage by site</h3>
        {% if coverage|length and coverageTotal > 0 %}
            <div class="dash-chart">
                <canvas data-craftsearch-chart="stacked-bar" data-craftsearch-series="{{ coverage|json_encode|e('html_attr') }}"></canvas>
            </div>
        {% else %}
            <p class="dash-empty">No entries indexed yet — <a href="{{ cpUrl('smart-search/index') }}">run your first sync</a>.</p>
        {% endif %}
    </div>

    <div class="pane">
        <h3 class="dash-title">Recent errors</h3>
        <table class="data fullwidth">
            <thead>
                <tr>
                    <th>Query / message</th>
                    <th class="rightalign">When</th>
                </tr>
            </thead>
            <tbody>
                {% for e in recentErrors %}
                    {% set label = e.query ?: e.errorMessage ?: 'error' %}
                    <tr>
                        <td>
                            {{ label|slice(0, 60) }}{% if label|length > 60 %}…{% endif %}
                            <button type="button" class="badge badge--error ss-error-badge"
                                    data-error-modal data-error-message="{{ e.errorMessage }}"
                                    title="{{ e.errorMessage }}"><span class="badge__dot"></span>Error</button>
                        </td>
                        <td class="rightalign"><span class="light">{{ e.dateCreated|date('M j, g:ia') }}</span></td>
                    </tr>
                {% else %}
                    <tr><td colspan="2" class="centeralign light">No errors recorded — search is healthy.</td></tr>
                {% endfor %}
            </tbody>
        </table>
        {% if recentErrors|length %}
            <p class="dash-cta"><a class="go" href="{{ cpUrl('smart-search/insights?tab=history&errorsOnly=1') }}">View all errors</a></p>
        {% endif %}
    </div>
</div>

{% include 'smart-search/_dashboard/_slow-queries' with { slowQueries: slowQueries } only %}

{% include 'smart-search/_dashboard/_recommendations' with { recommendations: recommendations, scope: 'advanced' } only %}
