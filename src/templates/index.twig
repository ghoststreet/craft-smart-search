{% extends "_layouts/cp" %}

{% set title = 'Smart Search' %}

{% set seriesSearches = [] %}
{% set seriesCost = [] %}
{% for r in dailySeries %}
    {% set seriesSearches = seriesSearches|merge([{ date: r.date, value: r.searches }]) %}
    {% set seriesCost = seriesCost|merge([{ date: r.date, value: r.cost }]) %}
{% endfor %}

{% set coverageTotals = { indexed: 0, stale: 0, notIndexed: 0 } %}
{% for c in coverage %}
    {% set coverageTotals = {
        indexed: coverageTotals.indexed + c.indexed,
        stale: coverageTotals.stale + c.stale,
        notIndexed: coverageTotals.notIndexed + c.notIndexed,
    } %}
{% endfor %}
{% set coverageTotal = coverageTotals.indexed + coverageTotals.stale + coverageTotals.notIndexed %}
{% set coveragePct = coverageTotal > 0 ? (coverageTotals.indexed / coverageTotal * 100)|round : 0 %}

{% set budgetClass = budget.ratio >= 0.9 ? 'budget-bar--crit' : (budget.ratio >= 0.75 ? 'budget-bar--warn' : '') %}
{% set budgetPct = (budget.ratio * 100)|round %}

{% block content %}
{% if not setupComplete %}
    <div class="dashboard dashboard--onboarding">
        {% include 'smart-search/_dashboard/_onboarding' with {
            settings: settings,
            stats: stats,
            requiredSteps: requiredSteps,
            recommendedSteps: recommendedSteps,
        } only %}
    </div>
{% else %}
<div class="dashboard">

    {# Integrated header bar: status pills (left) + range picker (right) #}
    <div class="dash-header">
        <div class="dash-header__status" role="status" aria-label="Smart Search health">
            {% for item in health %}
                <span class="dash-header__status-item dash-header__status-item--{{ item.state }}">
                    <span class="dash-header__dot" aria-hidden="true"></span>
                    <span>{{ item.label }}</span>
                </span>
            {% endfor %}
        </div>
        {% include 'smart-search/_dashboard/_range-picker' with { range: range, allowedRanges: allowedRanges } only %}
    </div>

    {% if not guideDismissed %}
        {% include 'smart-search/_dashboard/_guide-card' with { recommendedSteps: recommendedSteps, hasSearches: hasSearches } only %}
    {% endif %}

    {% set criticals = recommendations|filter(r => r.level == 'crit') %}
    {% if criticals|length %}
        <div class="dash-alerts">
            {% for c in criticals %}
                <div class="alert" role="alert">
                    <strong>{{ c.title }}.</strong> {{ c.body }}
                    {% if c.cta %} <a href="{{ c.cta.url }}">{{ c.cta.label }} →</a>{% endif %}
                </div>
            {% endfor %}
        </div>
    {% endif %}

    {# KPI hero row — 3 cards #}
    <div class="dash-kpis">
        {% include 'smart-search/_dashboard/_kpi-unified' with {
            aggregates: aggregates,
            seriesSearches: seriesSearches,
            seriesCost: seriesCost,
            budget: budget,
            budgetClass: budgetClass,
            budgetPct: budgetPct,
            stats: stats,
            coveragePct: coveragePct,
            coverageTotal: coverageTotal,
            coverageTotals: coverageTotals,
            isMultisite: isMultisite,
            siteCount: siteCount,
            indexedSiteCount: indexedSiteCount,
            daysWithData: daysWithData,
            minDaysBudgetEta: minDaysBudgetEta,
        } only %}
    </div>

    {# Top queries + Trending queries (50/50) #}
    <div class="dash-main">
        <div class="pane">
            <h3 class="dash-title">Top queries ({{ range }}d)</h3>
            <table class="data fullwidth">
                <thead>
                    <tr>
                        <th>Query</th>
                        <th class="rightalign">Hits</th>
                        <th class="rightalign">Avg results</th>
                    </tr>
                </thead>
                <tbody>
                    {% for q in topQueries %}
                        <tr>
                            <td>{{ q.query|slice(0, 80) }}{% if q.query|length > 80 %}…{% endif %}</td>
                            <td class="rightalign">{{ q.hits|number_format }}</td>
                            <td class="rightalign"><span class="light">{{ q.avgResults is defined ? q.avgResults|round(1) : '—' }}</span></td>
                        </tr>
                    {% else %}
                        <tr><td colspan="3" class="centeralign light">No search activity yet — queries will appear here once the front-end starts hitting the endpoint.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
            {% if topQueries|length %}
                <p class="dash-cta"><a class="go" href="{{ cpUrl('smart-search/insights') }}">View all queries</a></p>
            {% endif %}
        </div>

        {% include 'smart-search/_dashboard/_trending-queries' with { trendingQueries: trendingQueries } only %}
    </div>

    {% if recentErrors|length %}
        <div class="dash-row">
            <div class="pane">
                <h3 class="dash-title">Recent errors</h3>
                <table class="data fullwidth">
                    <tbody>
                        {% for e in recentErrors %}
                            {% set label = e.query ?: e.errorMessage ?: 'error' %}
                            <tr>
                                <td>
                                    {{ label|slice(0, 50) }}{% if label|length > 50 %}…{% endif %}
                                    <button type="button" class="badge badge--error ss-error-badge"
                                            data-craftsearch-control="error-modal-trigger"
                                            data-craftsearch-error-message="{{ e.errorMessage }}"
                                            title="{{ e.errorMessage }}"><span class="badge__dot"></span>Error</button>
                                </td>
                                <td class="rightalign"><span class="light smalltext">{{ e.dateCreated|date('M j') }}</span></td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
                <p class="dash-cta"><a class="go" href="{{ cpUrl('smart-search/insights?tab=history&errorsOnly=1') }}">View all errors</a></p>
            </div>
        </div>
    {% endif %}

    {% if isMultisite %}
        <div class="dash-row">
            {% include 'smart-search/_dashboard/_coverage-by-site' with { coverage: coverage, coverageTotal: coverageTotal } only %}
        </div>
    {% endif %}

    <div class="dash-row">
        {% include 'smart-search/_dashboard/_recommendations' with { recommendations: recommendations, show: 'action' } only %}
    </div>

    {% if hasSearches %}
        <div class="dash-row">
            {% include 'smart-search/_dashboard/_recommendations' with { recommendations: recommendations, show: 'suggestions' } only %}
        </div>
    {% endif %}


</div>
{% endif %}
{% endblock %}
