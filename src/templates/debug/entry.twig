{% extends "_layouts/cp" %}

{% set entry = inspection.entry %}
{% set chunkCount = inspection.chunks|length %}
{% set status = chunkCount > 0 ? 'indexed' : 'not-indexed' %}

{% set title = 'Debug: ' ~ (entry.title ?: '(untitled)') %}

{% set crumbs = [
    { label: 'AI Search', url: cpUrl('ai-search') },
    { label: 'Debug'|t('ai-search'), url: cpUrl('ai-search/debug') },
] %}

{% macro truncate(text, length) %}
    {%- if text|length > length -%}
        {{ text[:length] }}…
    {%- else -%}
        {{ text }}
    {%- endif -%}
{% endmacro %}

{% from _self import truncate %}

{% block actionButton %}
    {% if entry.cpEditUrl %}
        <a class="btn" href="{{ entry.cpEditUrl }}">{{ 'Open in editor'|t('ai-search') }}</a>
    {% endif %}
{% endblock %}

{% set details %}
    <div class="meta read-only">
        <div class="data">
            <h5 class="heading">{{ 'Status'|t('ai-search') }}</h5>
            <div class="value">
                {% if status == 'indexed' %}
                    <span class="status green"></span> {{ 'Indexed'|t('ai-search') }}
                {% elseif status == 'stale' %}
                    <span class="status orange"></span> {{ 'Stale'|t('ai-search') }}
                {% else %}
                    <span class="status off"></span> {{ 'Not indexed'|t('ai-search') }}
                {% endif %}
            </div>
        </div>
        <div class="data">
            <h5 class="heading">{{ 'ID'|t('ai-search') }}</h5>
            <div class="value"><code>{{ entry.id }}</code></div>
        </div>
        <div class="data">
            <h5 class="heading">{{ 'Title'|t('ai-search') }}</h5>
            <div class="value">{{ entry.title }}</div>
        </div>
        <div class="data">
            <h5 class="heading">{{ 'Section'|t('ai-search') }}</h5>
            <div class="value">{{ entry.section.name ?? '—' }}</div>
        </div>
        <div class="data">
            <h5 class="heading">{{ 'Site'|t('ai-search') }}</h5>
            <div class="value">{{ entry.site.name }}</div>
        </div>
        <div class="data">
            <h5 class="heading">{{ 'Date updated'|t('ai-search') }}</h5>
            <div class="value">{{ entry.dateUpdated|date('M j, Y g:i A') }}</div>
        </div>
        {% if entry.url %}
            <div class="data">
                <h5 class="heading">{{ 'URL'|t('ai-search') }}</h5>
                <div class="value"><a href="{{ entry.url }}" target="_blank" rel="noopener">{{ entry.url }}</a></div>
            </div>
        {% endif %}
    </div>
{% endset %}

{% block content %}
    {# Fields pane #}
    <div class="pane">
        <header class="pane-header">
            <h2>{{ 'Fields'|t('ai-search') }} <span class="light">({{ inspection.fields|length }})</span></h2>
        </header>
        <p class="instructions"><em>{{ 'Searchable'|t('ai-search') }}</em> {{ "is Craft's native field-layout setting."|t('ai-search') }} {{ 'Indexed reflects what this plugin actually extracts.'|t('ai-search') }}</p>

        {% if inspection.fields|length %}
            <table class="data fullwidth">
                <thead>
                    <tr>
                        <th scope="col">{{ 'Handle'|t('ai-search') }}</th>
                        <th scope="col">{{ 'Type'|t('ai-search') }}</th>
                        <th scope="col" class="thin">{{ 'Searchable'|t('ai-search') }}</th>
                        <th scope="col" class="thin">{{ 'Indexed'|t('ai-search') }}</th>
                        <th scope="col">{{ 'Extracted text'|t('ai-search') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for field in inspection.fields %}
                        <tr>
                            <td class="cell-bold"><code>{{ field.handle }}</code></td>
                            <td><span class="light">{{ field.type }}</span></td>
                            <td class="thin">
                                {% if field.searchable %}
                                    <span class="status green"></span> {{ 'Yes'|t('ai-search') }}
                                {% else %}
                                    <span class="status off"></span> {{ 'No'|t('ai-search') }}
                                {% endif %}
                            </td>
                            <td class="thin">
                                {% if field.indexed %}
                                    <span class="status green"></span> {{ 'Yes'|t('ai-search') }}
                                {% else %}
                                    <span class="status off"></span> {{ 'No'|t('ai-search') }}
                                {% endif %}
                                {% if field.reason %}
                                    <span class="info">{{ field.reason }}</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if field.extractedText %}
                                    <span class="debug-extracted">{{ truncate(field.extractedText, 300) }}</span>
                                {% else %}
                                    <span class="light">—</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
            <div class="zilch"><p>{{ 'No custom fields.'|t('ai-search') }}</p></div>
        {% endif %}
    </div>

    {# Chunks pane #}
    <div class="pane" style="margin-top: 24px;">
        <header class="pane-header">
            <h2>{{ 'Chunks'|t('ai-search') }} <span class="light">({{ chunkCount }})</span></h2>
        </header>
        <p class="instructions">{{ 'Stored rows from'|t('ai-search') }} <code>aisearch_vectors</code>. {{ 'Concatenating these (after the title prefix) reconstructs the indexed text.'|t('ai-search') }}</p>

        {% if chunkCount %}
            <div class="chunk-list">
                {% for chunk in inspection.chunks %}
                    {% include 'ai-search/debug/_chunk-row' with { chunk: chunk } only %}
                {% endfor %}
            </div>
        {% else %}
            <div class="zilch">
                <p>{{ 'No chunks stored — this entry is not indexed yet.'|t('ai-search') }}</p>
            </div>
        {% endif %}
    </div>
{% endblock %}
