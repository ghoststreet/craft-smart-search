{% extends "_layouts/cp" %}
{% import "_includes/forms.twig" as forms %}

{% set title = 'Indexing Debug'|t('ai-search') %}
{% set fullPageForm = false %}

{% set crumbs = [
    { label: 'AI Search', url: cpUrl('ai-search') },
] %}

{% set counts = result.counts ?? { indexed: 0, stale: 0, 'not-indexed': 0, total: result.total } %}

{% block content %}
    {% if error %}
        <div class="readable">
            <blockquote class="note warning">
                <p><strong>{{ 'Database error.'|t('ai-search') }}</strong> {{ error }}</p>
            </blockquote>
        </div>
    {% endif %}

    {% set siteOptions = [] %}
    {% for site in sites %}
        {% set siteOptions = siteOptions|merge([{ label: site.name, value: site.id }]) %}
    {% endfor %}

    {% set sectionOptions = [{ label: 'All indexable sections'|t('ai-search'), value: '' }] %}
    {% for section in sections %}
        {% if settings.indexableSections is empty or section.handle in settings.indexableSections %}
            {% set sectionOptions = sectionOptions|merge([{ label: section.name, value: section.handle }]) %}
        {% endif %}
    {% endfor %}

    {% set statusOptions = [
        { label: 'All'|t('ai-search'), value: '' },
        { label: 'Indexed'|t('ai-search'), value: 'indexed' },
        { label: 'Stale'|t('ai-search'), value: 'stale' },
        { label: 'Not indexed'|t('ai-search'), value: 'not-indexed' },
    ] %}

    <form method="get" action="" class="ai-search-toolbar">
        <div id="toolbar" class="flex flex-nowrap">
            {% if sites|length > 1 %}
                {{ forms.selectField({
                    label: 'Site'|t('ai-search'),
                    name: 'siteId',
                    value: filters.siteId,
                    options: siteOptions,
                }) }}
            {% else %}
                <input type="hidden" name="siteId" value="{{ filters.siteId }}">
            {% endif %}

            {{ forms.selectField({
                label: 'Section'|t('ai-search'),
                name: 'section',
                value: filters.section,
                options: sectionOptions,
            }) }}

            {{ forms.selectField({
                label: 'Status'|t('ai-search'),
                name: 'status',
                value: filters.status,
                options: statusOptions,
            }) }}

            <div class="field">
                <div class="heading">&nbsp;</div>
                <div class="input">
                    <button type="submit" class="btn submit">{{ 'Filter'|t('ai-search') }}</button>
                </div>
            </div>
        </div>
    </form>

    <div class="ai-search-stats">
        <div class="meta-item">
            <span class="count">{{ counts.total }}</span>
            <span class="label">{{ 'Total'|t('ai-search') }}</span>
        </div>
        <div class="meta-item">
            <span class="status green"></span>
            <span class="count">{{ counts.indexed }}</span>
            <span class="label">{{ 'Indexed'|t('ai-search') }}</span>
        </div>
        <div class="meta-item">
            <span class="status orange"></span>
            <span class="count">{{ counts.stale }}</span>
            <span class="label">{{ 'Stale'|t('ai-search') }}</span>
        </div>
        <div class="meta-item">
            <span class="status off"></span>
            <span class="count">{{ counts['not-indexed'] }}</span>
            <span class="label">{{ 'Not indexed'|t('ai-search') }}</span>
        </div>
    </div>

    {% if result.rows|length %}
        <table class="data fullwidth">
            <thead>
                <tr>
                    <th scope="col">{{ 'Title'|t('ai-search') }}</th>
                    <th scope="col">{{ 'Section'|t('ai-search') }}</th>
                    <th scope="col" class="thin">{{ 'Status'|t('ai-search') }}</th>
                    <th scope="col" class="thin">{{ 'Chunks'|t('ai-search') }}</th>
                    <th scope="col" class="thin">{{ 'Last indexed'|t('ai-search') }}</th>
                </tr>
            </thead>
            <tbody>
                {% for row in result.rows %}
                    <tr>
                        <td class="cell-bold">
                            <a href="{{ cpUrl('ai-search/debug/entry', { elementId: row.elementId, siteId: row.siteId }) }}">{{ row.title ?: '(untitled)'|t('ai-search') }}</a>
                        </td>
                        <td>{{ row.section }}</td>
                        <td class="thin">
                            {% if row.status == 'indexed' %}
                                <span class="status green"></span> {{ 'Indexed'|t('ai-search') }}
                            {% elseif row.status == 'stale' %}
                                <span class="status orange"></span> {{ 'Stale'|t('ai-search') }}
                            {% else %}
                                <span class="status off"></span> {{ 'Not indexed'|t('ai-search') }}
                            {% endif %}
                        </td>
                        <td class="thin">{{ row.chunkCount }}</td>
                        <td class="thin">
                            {% if row.lastIndexed %}
                                {{ row.lastIndexed|date('M j, Y g:i A') }}
                            {% else %}
                                <span class="light">—</span>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <div class="zilch">
            <p>{{ 'No entries match these filters.'|t('ai-search') }}</p>
        </div>
    {% endif %}

    {% set totalPages = (result.total / result.pageSize)|round(0, 'ceil') %}
    {% if totalPages > 1 %}
        <div class="pagination">
            <div class="btngroup">
                {% if result.page > 1 %}
                    <a class="btn" href="{{ url(craft.app.request.pathInfo, filters|merge({ page: result.page - 1 })) }}">
                        <span data-icon="leftangle"></span> {{ 'Prev'|t('ai-search') }}
                    </a>
                {% else %}
                    <span class="btn disabled"><span data-icon="leftangle"></span> {{ 'Prev'|t('ai-search') }}</span>
                {% endif %}
                {% if result.page < totalPages %}
                    <a class="btn" href="{{ url(craft.app.request.pathInfo, filters|merge({ page: result.page + 1 })) }}">
                        {{ 'Next'|t('ai-search') }} <span data-icon="rightangle"></span>
                    </a>
                {% else %}
                    <span class="btn disabled">{{ 'Next'|t('ai-search') }} <span data-icon="rightangle"></span></span>
                {% endif %}
            </div>
            <span class="page-label">{{ 'Page {p} of {t}'|t('ai-search', { p: result.page, t: totalPages }) }}</span>
        </div>
    {% endif %}
{% endblock %}
