{% import '_includes/forms.twig' as forms %}

<h2>API access</h2>
<p class="light">Control who can call the plugin's search endpoints.</p>

{% namespace 'settings' %}
    {{ forms.autosuggestField({
        label: 'API token',
        instructions: 'Bearer token required on every API request. Leave empty to allow requests from your own site (CSRF and origin checks still apply).',
        id: 'apiToken', name: 'apiToken',
        value: settings.apiToken, suggestEnvVars: true,
        errors: settings.getErrors('apiToken'),
    }) }}
{% endnamespace %}

{% if settings.getApiToken() and not settings.allowedOrigins %}
    <p class="light settings__cors-tip">
        Heads up: headless front-ends calling from another origin will be blocked by CORS until you add their origin below.
    </p>
{% endif %}

{% namespace 'settings' %}
    {{ forms.autosuggestField({
        label: 'Allowed origins',
        instructions: 'Comma-separated list of extra origins permitted to call the API from the browser. Requests from the same origin as your Craft site are always allowed.',
        id: 'allowedOrigins', name: 'allowedOrigins',
        value: settings.allowedOrigins, suggestEnvVars: true,
        placeholder: 'https://app.example.com',
        errors: settings.getErrors('allowedOrigins'),
    }) }}
{% endnamespace %}

<hr>

<h2>Diagnostics</h2>
<p class="light">Control how long detailed search history is kept for debugging and analytics.</p>

{% namespace 'settings' %}
    {{ forms.textField({
        label: 'History retention (days)',
        instructions: 'Number of days to keep query text and result payloads. Token usage and cost are kept permanently so long-term stats stay accurate.',
        id: 'historyRetentionDays', name: 'historyRetentionDays',
        value: settings.historyRetentionDays, type: 'number', min: '1', max: '365',
        required: true, errors: settings.getErrors('historyRetentionDays'),
    }) }}

{% endnamespace %}
