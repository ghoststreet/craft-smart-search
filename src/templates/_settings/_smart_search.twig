{% import '_includes/forms.twig' as forms %}

<h2>Ranking</h2>
<p class="light">Results are scored by meaning (semantic) and exact words (keyword). The weights below decide how the two are mixed and must add up to <code>1.00</code>. <a href="{{ wikiUrl }}/Tuning-Search-Results" target="_blank" rel="noopener">Learn more</a>.</p>

{% namespace 'settings' %}
    {{ forms.textField({
        label: 'Semantic weight',
        instructions: 'How much meaning-based matching counts toward the final ranking. Must add up to <code>1</code> with the keyword weight. Default <code>0.3</code>.',
        id: 'rrfSemanticWeight', name: 'rrfSemanticWeight',
        value: settings.rrfSemanticWeight, type: 'number', step: '0.1', min: '0', max: '1',
        required: true, errors: settings.getErrors('rrfSemanticWeight'),
    }) }}

    {{ forms.textField({
        label: 'Keyword weight',
        instructions: 'How much exact keyword matching counts toward the final ranking. Must add up to <code>1</code> with the semantic weight. Default <code>0.7</code>.',
        id: 'rrfKeywordWeight', name: 'rrfKeywordWeight',
        value: settings.rrfKeywordWeight, type: 'number', step: '0.1', min: '0', max: '1',
        required: true, errors: settings.getErrors('rrfKeywordWeight'),
    }) }}

    {{ forms.textField({
        label: 'Minimum semantic score',
        instructions: 'How close in meaning a result must be before it shows. Raise it to filter weak matches; lower it if relevant pages are missing. Default <code>0.15</code>.',
        id: 'minSemanticThreshold', name: 'minSemanticThreshold',
        value: settings.minSemanticThreshold, type: 'number', step: '0.05', min: '0', max: '1',
        required: true, errors: settings.getErrors('minSemanticThreshold'),
    }) }}

    {{ forms.textField({
        label: 'Candidate pool size',
        instructions: 'How many results Smart Search considers per query before picking the best. Bigger casts a wider net but slows searches. Default <code>100</code>.',
        id: 'maxSemanticResults', name: 'maxSemanticResults',
        value: settings.maxSemanticResults, type: 'number', min: '10', max: '500',
        required: true, errors: settings.getErrors('maxSemanticResults'),
    }) }}
{% endnamespace %}

<hr>

<h2>Result display</h2>

{% namespace 'settings' %}
    {{ forms.textField({
        label: 'Excerpt length (characters)',
        instructions: 'Length of the preview snippet shown under each result. Default <code>200</code>.',
        id: 'excerptLength', name: 'excerptLength',
        value: settings.excerptLength, type: 'number', min: '50', max: '500',
        required: true, errors: settings.getErrors('excerptLength'),
    }) }}
{% endnamespace %}

<hr>

<h2>Typo tolerance</h2>
<p class="light">Matches misspellings like <code>aple</code> against indexed terms like <code>apple</code>. Needs the Postgres <code>pg_trgm</code> extension. <a href="{{ wikiUrl }}/Installation#typo-tolerance" target="_blank" rel="noopener">Setup steps</a>.</p>

{% set dictionaryService = craft.app.plugins.getPlugin('smart-search').dictionaryService %}
{% set trgmInstalled = dictionaryService.hasTrgmExtension() %}
{% set fuzzyInstalled = dictionaryService.hasFuzzyStrMatch() %}
{% set termCount = dictionaryService.getTermCount() %}

{% if not trgmInstalled %}
    <p class="warning with-icon">
        <strong>Setup required.</strong> Install the <code>pg_trgm</code> Postgres extension on your vectors database to use typo tolerance.
    </p>
{% else %}
    <p class="notice with-icon">
        <strong>{% if settings.enableTypoTolerance %}Active.{% else %}Off.{% endif %}</strong>
        Dictionary has <strong>{{ termCount }}</strong> term{{ termCount == 1 ? '' : 's' }}.
        {% if termCount == 0 %}
            It fills itself the next time content is indexed, or run <code>./craft smart-search/dictionary/rebuild</code> now.
        {% endif %}
    </p>
{% endif %}

{% namespace 'settings' %}
    {{ forms.lightswitchField({
        label: 'Enable typo tolerance',
        instructions: trgmInstalled
            ? 'Correct single-character typos in keyword queries using the dictionary. Optionally install <code>fuzzystrmatch</code> for tighter accuracy. Default <code>on</code>.'
            : 'Install the <code>pg_trgm</code> extension above to enable this control.',
        id: 'enableTypoTolerance', name: 'enableTypoTolerance',
        on: settings.enableTypoTolerance,
        disabled: not trgmInstalled,
        errors: settings.getErrors('enableTypoTolerance'),
    }) }}

{% endnamespace %}

<hr>

<h2>Rate limits</h2>
<p class="light">Caps how many searches one visitor can run, so a single person or bot cannot overload the API. Set either limit to <code>0</code> to turn it off. Behind a CDN, configure Craft’s <code>request.trustedHosts</code> and <code>ipHeaders</code> so the real visitor IP is read. <a href="{{ wikiUrl }}/Troubleshooting#behind-a-cdn-or-proxy" target="_blank" rel="noopener">Learn more</a>.</p>

{% namespace 'settings' %}
    {{ forms.textField({
        label: 'Searches per minute (per visitor)',
        instructions: 'Set to <code>0</code> to turn off. Default <code>10</code>.',
        id: 'rateLimitSearchPerMinute', name: 'rateLimitSearchPerMinute',
        value: settings.rateLimitSearchPerMinute, type: 'number', min: '0', max: '100000',
        required: true, errors: settings.getErrors('rateLimitSearchPerMinute'),
    }) }}
    {{ forms.textField({
        label: 'Searches per hour (per visitor)',
        instructions: 'Set to <code>0</code> to turn off. Default <code>30</code>.',
        id: 'rateLimitSearchPerHour', name: 'rateLimitSearchPerHour',
        value: settings.rateLimitSearchPerHour, type: 'number', min: '0', max: '100000',
        required: true, errors: settings.getErrors('rateLimitSearchPerHour'),
    }) }}
{% endnamespace %}
