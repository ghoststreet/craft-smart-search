{% import '_includes/forms.twig' as forms %}

<h2>Ranking</h2>
<p class="light">Every search is scored by two signals: <strong>semantic</strong> (results that match the meaning of the query) and <strong>keyword</strong> (results that contain the exact words). The settings below decide how those two scores are mixed and how strict the final cut-off is. Defaults are tuned for general-purpose sites.</p>
<p class="light">Think of <strong>Semantic weight</strong> and <strong>Keyword weight</strong> as slices of a pie: how much of the final ranking each signal gets to decide. They must add up to <code>1.00</code> (e.g. <code>0.7 + 0.3</code>, or <code>0.5 + 0.5</code>); the form won't save until they do. If you slide the meaning weight up, exact-word matches matter less; slide it down and the opposite happens.</p>

{% namespace 'settings' %}
    {{ forms.textField({
        label: 'Semantic weight',
        instructions: 'How much meaning-based matching (vectors) counts toward the final ranking. Range 0–1; should add up to 1 with the keyword weight below. <a href="' ~ wikiUrl ~ '/Tuning-Search-Results#semantic-weight" target="_blank" rel="noopener">Learn more →</a>',
        id: 'rrfSemanticWeight', name: 'rrfSemanticWeight',
        value: settings.rrfSemanticWeight, type: 'number', step: '0.1', min: '0', max: '1',
        required: true, errors: settings.getErrors('rrfSemanticWeight'),
    }) }}

    {{ forms.textField({
        label: 'Keyword weight',
        instructions: 'How much exact keyword matching  counts toward the final ranking. Range 0–1; should add up to 1 with the semantic weight above. <a href="' ~ wikiUrl ~ '/Tuning-Search-Results#keyword-weight" target="_blank" rel="noopener">Learn more →</a>',
        id: 'rrfKeywordWeight', name: 'rrfKeywordWeight',
        value: settings.rrfKeywordWeight, type: 'number', step: '0.1', min: '0', max: '1',
        required: true, errors: settings.getErrors('rrfKeywordWeight'),
    }) }}

    {{ forms.textField({
        label: 'Minimum semantic score',
        instructions: 'How close in meaning a result has to be to the search before Smart Search shows it. Raise it if weak guesses are slipping through; lower it if relevant pages are missing. Range 0–1. <a href="' ~ wikiUrl ~ '/Tuning-Search-Results#minimum-semantic-score" target="_blank" rel="noopener">Learn more →</a>',
        id: 'minSemanticThreshold', name: 'minSemanticThreshold',
        value: settings.minSemanticThreshold, type: 'number', step: '0.05', min: '0', max: '1',
        required: true, errors: settings.getErrors('minSemanticThreshold'),
    }) }}

    {{ forms.textField({
        label: 'Candidate pool size',
        instructions: 'How many results Smart Search looks at per query before picking the best ones to show. Bigger numbers cast a wider net but slow searches down. Leave at <code>100</code> unless searches feel slow or you’re missing relevant results. <a href="' ~ wikiUrl ~ '/Tuning-Search-Results#candidate-pool-size" target="_blank" rel="noopener">Learn more →</a>',
        id: 'maxSemanticResults', name: 'maxSemanticResults',
        value: settings.maxSemanticResults, type: 'number', min: '10', max: '500',
        required: true, errors: settings.getErrors('maxSemanticResults'),
    }) }}
{% endnamespace %}

<hr>

<h2>Result display</h2>

{% namespace 'settings' %}
    {{ forms.textField({
        label: 'Excerpt length (characters)',
        instructions: 'How long the preview snippet under each result is. Shorter feels tidier; longer gives visitors more context to pick the right page. Range 50–500.',
        id: 'excerptLength', name: 'excerptLength',
        value: settings.excerptLength, type: 'number', min: '50', max: '500',
        required: true, errors: settings.getErrors('excerptLength'),
    }) }}
{% endnamespace %}

<hr>

<h2>Typo tolerance</h2>
<p class="light">Matches misspellings like <code>aple</code> against indexed terms like <code>apple</code>. Needs the PostgreSQL <code>pg_trgm</code> extension (required) and the <code>fuzzystrmatch</code> extension (optional, sharpens accuracy), plus a corpus dictionary that Smart Search builds for you. <a href="{{ wikiUrl }}/Installation#typo-tolerance" target="_blank" rel="noopener">Learn more →</a></p>

{% set dictionaryService = craft.app.plugins.getPlugin('smart-search').dictionaryService %}
{% set trgmInstalled = dictionaryService.hasTrgmExtension() %}
{% set fuzzyInstalled = dictionaryService.hasFuzzyStrMatch() %}
{% set termCount = dictionaryService.getTermCount() %}

{% if not trgmInstalled %}
    <p class="warning with-icon">
        <strong>Setup required.</strong> Typo tolerance needs the <code>pg_trgm</code> Postgres extension (and benefits from <code>fuzzystrmatch</code>) installed on your vectors database. <a href="{{ wikiUrl }}/Installation#typo-tolerance" target="_blank" rel="noopener">See the setup steps →</a>
    </p>
{% elseif termCount == 0 %}
    <p class="notice with-icon">
        <strong>Almost there.</strong> The extension is installed but the dictionary is empty. It fills itself the next time content is added or re-indexed, or you can build it now by running <code>./craft smart-search/dictionary/rebuild</code>.
    </p>
    {% if not fuzzyInstalled %}
        <p class="light"><em>Optional:</em> install <code>CREATE EXTENSION fuzzystrmatch;</code> for tighter accuracy via Levenshtein edit-distance caps.</p>
    {% endif %}
{% else %}
    <p class="notice with-icon">
        <strong>{% if settings.enableTypoTolerance %}Active.{% else %}Off.{% endif %}</strong>
        Dictionary has <strong>{{ termCount }}</strong> term{{ termCount == 1 ? '' : 's' }}.
        {% if settings.enableTypoTolerance %}
            Misspellings like <em>aple</em> are corrected to <em>apple</em> before search runs.
        {% else %}
            Typo'd queries are not corrected (toggle is off below).
        {% endif %}
    </p>
    {% if not fuzzyInstalled %}
        <p class="light"><em>Optional:</em> install <code>CREATE EXTENSION fuzzystrmatch;</code> for tighter accuracy via Levenshtein edit-distance caps.</p>
    {% endif %}
{% endif %}

{% namespace 'settings' %}
    {{ forms.lightswitchField({
        label: 'Enable typo tolerance',
        instructions: trgmInstalled
            ? 'Expand keyword query terms with dictionary lookups so single-character typos still match.'
            : 'Install the <code>pg_trgm</code> extension above to enable this control.',
        id: 'enableTypoTolerance', name: 'enableTypoTolerance',
        on: settings.enableTypoTolerance,
        disabled: not trgmInstalled,
        errors: settings.getErrors('enableTypoTolerance'),
    }) }}

{% endnamespace %}

<hr>

<h2>Rate limits</h2>
<p class="light">Caps how many searches a single visitor can run in a short time, so one person or bot can’t overload the search API. Set either limit to <code>0</code> to turn it off.</p>
<p class="light">If your site sits behind a CDN or reverse proxy, configure Craft’s <code>request.trustedHosts</code> and <code>ipHeaders</code> so the plugin can read the real visitor IP. Otherwise every request will look like it came from your proxy and one shared limit will affect everyone. <a href="{{ wikiUrl }}/Troubleshooting#behind-a-cdn-or-proxy" target="_blank" rel="noopener">Learn more →</a></p>

{% namespace 'settings' %}
    {{ forms.textField({
        label: 'Searches per minute (per visitor)',
        instructions: 'How many searches one visitor can run in any 60-second stretch. Stops bursts. Set to <code>0</code> to turn off.',
        id: 'rateLimitSearchPerMinute', name: 'rateLimitSearchPerMinute',
        value: settings.rateLimitSearchPerMinute, type: 'number', min: '0', max: '100000',
        required: true, errors: settings.getErrors('rateLimitSearchPerMinute'),
    }) }}
    {{ forms.textField({
        label: 'Searches per hour (per visitor)',
        instructions: 'How many searches one visitor can run in any 60-minute stretch. Stops sustained scraping. Set to <code>0</code> to turn off.',
        id: 'rateLimitSearchPerHour', name: 'rateLimitSearchPerHour',
        value: settings.rateLimitSearchPerHour, type: 'number', min: '0', max: '100000',
        required: true, errors: settings.getErrors('rateLimitSearchPerHour'),
    }) }}
{% endnamespace %}
