{% import '_includes/forms.twig' as forms %}

{% namespace 'settings' %}
<h2>API access</h2>
<p class="light">Controls who can call Smart Search’s HTTP endpoints from outside your Craft site. <a href="{{ wikiUrl }}/Security" target="_blank" rel="noopener">Learn more</a>.</p>

    {{ forms.autosuggestField({
        label: 'API bearer token',
        instructions: 'Required on every external API request as <code>Authorization: Bearer &lt;token&gt;</code>. Leave empty to only allow calls from your own Craft site.',
        id: 'apiToken', name: 'apiToken',
        value: settings.apiToken, suggestEnvVars: true,
        errors: settings.getErrors('apiToken'),
    }) }}

{% if settings.getApiToken() and not settings.allowedOrigins %}
    <p class="light">
        Heads up: headless front ends calling from another origin will be blocked by CORS until you add their origin below.
    </p>
{% endif %}

    {{ forms.autosuggestField({
        label: 'Allowed origins (CORS)',
        instructions: 'Comma-separated origins allowed to call the API from a browser (e.g. <code>https://app.example.com</code>). Same-origin calls are always allowed.',
        id: 'allowedOrigins', name: 'allowedOrigins',
        value: settings.allowedOrigins, suggestEnvVars: true,
        placeholder: 'https://app.example.com',
        errors: settings.getErrors('allowedOrigins'),
    }) }}
{% endnamespace %}
