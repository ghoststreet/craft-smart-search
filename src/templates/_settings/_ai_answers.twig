{% import '_includes/forms.twig' as forms %}

<h2>Behavior</h2>

{% namespace 'settings' %}
    {{ forms.selectField({
        label: 'Answer model',
        instructions: 'OpenAI model that generates summaries for /api/rag-search.',
        id: 'ragModel', name: 'ragModel',
        value: settings.ragModel,
        options: [{ label: 'gpt-5.4-nano', value: 'gpt-5.4-nano' }],
        required: true, errors: settings.getErrors('ragModel'),
    }) }}

    {{ forms.textField({
        label: 'Max prompt tokens',
        id: 'maxPromptTokens', name: 'maxPromptTokens',
        value: settings.maxPromptTokens, type: 'number', min: '500', max: '100000',
        required: true, errors: settings.getErrors('maxPromptTokens'),
    }) }}

    {{ forms.textareaField({
        label: 'Custom system prompt',
        instructions: 'Optional instructions appended to the default system prompt.',
        id: 'ragCustomPrompt', name: 'ragCustomPrompt', value: settings.ragCustomPrompt, rows: 5,
        errors: settings.getErrors('ragCustomPrompt'),
    }) }}
{% endnamespace %}

<hr>

<h2>Limits</h2>
<p class="light">When the cap is reached, RAG requests transparently fall back to hybrid search (no AI summary) so users still get results. Budget resets every 24 hours.</p>

{% namespace 'settings' %}
    {{ forms.textField({
        label: 'Global daily cap (USD)',
        id: 'costBudgetDailyGlobal', name: 'costBudgetDailyGlobal',
        value: settings.costBudgetDailyGlobal, type: 'number', step: '0.01', min: '0',
        errors: settings.getErrors('costBudgetDailyGlobal'),
    }) }}
    <p class="light">View current usage and spend on the <a href="{{ url('ai-search/insights') }}">Insights</a> page.</p>

    {{ forms.textField({
        label: 'AI answers per minute (per IP)',
        instructions: '0 disables this window.',
        id: 'rateLimitRagPerMinute', name: 'rateLimitRagPerMinute',
        value: settings.rateLimitRagPerMinute, type: 'number', min: '0', max: '100000',
        required: true, errors: settings.getErrors('rateLimitRagPerMinute'),
    }) }}
    {{ forms.textField({
        label: 'AI answers per hour (per IP)',
        instructions: '0 disables this window.',
        id: 'rateLimitRagPerHour', name: 'rateLimitRagPerHour',
        value: settings.rateLimitRagPerHour, type: 'number', min: '0', max: '100000',
        required: true, errors: settings.getErrors('rateLimitRagPerHour'),
    }) }}
    {{ forms.textField({
        label: 'Max concurrent AI answers per IP',
        id: 'ragConcurrencyPerIp', name: 'ragConcurrencyPerIp',
        value: settings.ragConcurrencyPerIp, type: 'number', min: '1', max: '100000',
        required: true, errors: settings.getErrors('ragConcurrencyPerIp'),
    }) }}
    {{ forms.textField({
        label: 'Max concurrent AI answers (global)',
        id: 'ragConcurrencyGlobal', name: 'ragConcurrencyGlobal',
        value: settings.ragConcurrencyGlobal, type: 'number', min: '1', max: '100000',
        required: true, errors: settings.getErrors('ragConcurrencyGlobal'),
    }) }}
{% endnamespace %}
