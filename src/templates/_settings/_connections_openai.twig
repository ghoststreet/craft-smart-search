{% import '_includes/forms.twig' as forms %}

<h2 id="connection-openai">OpenAI</h2>
<p class="light">Your OpenAI key powers embeddings and AI Answer. <a href="{{ wikiUrl }}/Connections#openai-api-key" target="_blank" rel="noopener">Setup guide</a>.</p>

{% namespace 'settings' %}
    {{ forms.autosuggestField({
        label: 'OpenAI API key',
        instructions: 'Reference an env var like <code>$OPENAI_API_KEY</code> instead of pasting the raw key.',
        id: 'openaiApiKey', name: 'openaiApiKey',
        value: settings.openaiApiKey, suggestEnvVars: true, required: true,
        errors: settings.getErrors('openaiApiKey'),
        inputAttributes: { 'data-craftsearch-target': 'openai-api-key' },
    }) }}

    <div class="buttons settings__buttons">
        <button type="button" class="btn disabled" data-craftsearch-control="test-api-key" disabled>Test API key</button>
        <span class="settings__test-result" data-craftsearch-target="test-api-key-result"></span>
    </div>

    {{ forms.selectField({
        label: 'Embedding model',
        instructions: 'Turns content and queries into vectors. Changing this requires a full reindex. Default <code>text-embedding-3-small</code>.',
        id: 'embeddingModel', name: 'embeddingModel',
        value: settings.embeddingModel,
        options: [
            { label: 'text-embedding-3-small (recommended)', value: 'text-embedding-3-small' },
            { label: 'text-embedding-3-large (higher accuracy, ~6× cost)', value: 'text-embedding-3-large' },
        ],
        required: true, errors: settings.getErrors('embeddingModel'),
        inputAttributes: { 'data-craftsearch-target': 'smart-embedding-model' },
    }) }}
    <p class="warning with-icon settings__reindex-warning" data-craftsearch-target="smart-embedding-warning" hidden>
        Saving will invalidate the existing vector corpus. A full reindex is required after this change.
    </p>

    {{ forms.selectField({
        label: 'Answer model',
        instructions: 'OpenAI model that writes the AI summary. Prices show input / output cost per 1M tokens. Default <code>gpt-5.4-nano</code>.',
        id: 'aiAnswerModel', name: 'aiAnswerModel',
        value: settings.aiAnswerModel,
        options: [
            { label: 'GPT-5.4 Nano. Fastest, cheapest ($0.20 / $1.25 per 1M tokens)', value: 'gpt-5.4-nano' },
            { label: 'GPT-5.4 Mini. Balanced ($0.75 / $4.50 per 1M tokens)', value: 'gpt-5.4-mini' },
            { label: 'GPT-5.4. Highest quality, slowest ($2.50 / $15.00 per 1M tokens)', value: 'gpt-5.4' },
        ],
        required: true, errors: settings.getErrors('aiAnswerModel'),
    }) }}
{% endnamespace %}
