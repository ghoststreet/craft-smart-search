{% import '_includes/forms.twig' as forms %}

{% namespace 'settings' %}
<h2>Behaviour</h2>
<p class="light">AI Answer reads the top search results and writes a short summary with citations. It runs only when you call it from your front end or a Twig template. <a href="{{ wikiUrl }}/Using-the-API#ai-answer-endpoint" target="_blank" rel="noopener">Learn more</a>.</p>

    {{ forms.textField({
        label: 'AI answer context size (tokens)',
        instructions: 'How much search content is packed into each AI Answer. More tokens give richer answers but cost more and run slower. Default <code>12000</code>.',
        id: 'maxPromptTokens', name: 'maxPromptTokens',
        value: settings.maxPromptTokens, type: 'number', min: '500', max: '100000',
        required: true, errors: settings.getErrors('maxPromptTokens'),
    }) }}

    {{ forms.textareaField({
        label: 'Extra system instructions',
        instructions: 'Optional. Appended to the built-in prompt as Site Context. Use it for tone, persona, or domain vocabulary. Cannot override grounding, citation, or scope rules.',
        id: 'aiAnswerCustomPrompt', name: 'aiAnswerCustomPrompt', value: settings.aiAnswerCustomPrompt, rows: 5,
        errors: settings.getErrors('aiAnswerCustomPrompt'),
    }) }}

<hr>

<h2>Limits</h2>

    {{ forms.textField({
        label: 'Daily spend cap (USD)',
        instructions: 'Maximum dollars spent on AI Answer per day across all visitors. Resets every 24 hours. When reached, AI Answer falls back to plain search. Default <code>3</code>.',
        id: 'costBudgetDailyGlobal', name: 'costBudgetDailyGlobal',
        value: settings.costBudgetDailyGlobal, type: 'number', step: '0.01', min: '0',
        errors: settings.getErrors('costBudgetDailyGlobal'),
    }) }}
    {% if insightsAvailable ?? false %}
        <p class="light">View current usage and spend on the <a href="{{ url('smart-search/insights') }}">Insights</a> page.</p>
    {% endif %}

    {{ forms.textField({
        label: 'AI Answer per minute (per visitor)',
        instructions: 'Set to <code>0</code> to turn off. Default <code>30</code>.',
        id: 'rateLimitAiAnswerPerMinute', name: 'rateLimitAiAnswerPerMinute',
        value: settings.rateLimitAiAnswerPerMinute, type: 'number', min: '0', max: '100000',
        required: true, errors: settings.getErrors('rateLimitAiAnswerPerMinute'),
    }) }}
    {{ forms.textField({
        label: 'AI Answer per hour (per visitor)',
        instructions: 'Set to <code>0</code> to turn off. Default <code>30</code>.',
        id: 'rateLimitAiAnswerPerHour', name: 'rateLimitAiAnswerPerHour',
        value: settings.rateLimitAiAnswerPerHour, type: 'number', min: '0', max: '100000',
        required: true, errors: settings.getErrors('rateLimitAiAnswerPerHour'),
    }) }}
    {{ forms.textField({
        label: 'Concurrent AI Answer per visitor',
        instructions: 'How many AI Answer requests one IP can run at the same time. Default <code>2</code>.',
        id: 'aiAnswerConcurrencyPerIp', name: 'aiAnswerConcurrencyPerIp',
        value: settings.aiAnswerConcurrencyPerIp, type: 'number', min: '1', max: '100000',
        required: true, errors: settings.getErrors('aiAnswerConcurrencyPerIp'),
    }) }}
    {{ forms.textField({
        label: 'Concurrent AI Answer (whole site)',
        instructions: 'Safety valve against traffic spikes across all visitors. Default <code>10</code>.',
        id: 'aiAnswerConcurrencyGlobal', name: 'aiAnswerConcurrencyGlobal',
        value: settings.aiAnswerConcurrencyGlobal, type: 'number', min: '1', max: '100000',
        required: true, errors: settings.getErrors('aiAnswerConcurrencyGlobal'),
    }) }}
{% endnamespace %}
