{% import '_includes/forms.twig' as forms %}

<h2>OpenAI</h2>
<p class="light">Required to generate embeddings and run AI answers. <a href="https://github.com/ghost-street/craft-ai-search#setup" target="_blank">Setup docs →</a></p>

{% namespace 'settings' %}
    {{ forms.autosuggestField({
        label: 'API key',
        instructions: 'Reference an environment variable, e.g. <code>$OPENAI_API_KEY</code>.',
        id: 'openaiApiKey', name: 'openaiApiKey',
        value: settings.openaiApiKey, suggestEnvVars: true, required: true,
        errors: settings.getErrors('openaiApiKey'),
        inputAttributes: { 'data-craftsearch-target': 'openai-api-key' },
    }) }}
{% endnamespace %}

<div class="buttons settings__buttons">
    <button type="button" class="btn disabled" data-craftsearch-control="test-api-key" disabled>Test API key</button>
    <span class="settings__test-result" data-craftsearch-target="test-api-key-result"></span>
</div>

<hr>

<h2>PostgreSQL</h2>
<p class="light">PostgreSQL with pgvector. The plugin does not create the schema — see the <a href="https://github.com/ghost-street/craft-ai-search#database-setup-required-admin-owned" target="_blank">README</a>.</p>

{% namespace 'settings' %}
    {{ forms.autosuggestField({ label: 'Host', id: 'postgresqlHost', name: 'postgresqlHost', value: settings.postgresqlHost, suggestEnvVars: true, required: true, placeholder: 'db.xxxx.supabase.co or $SUPABASE_DB_HOST', errors: settings.getErrors('postgresqlHost'), inputAttributes: { 'data-craftsearch-target': 'db-host' } }) }}
    {{ forms.autosuggestField({ label: 'Port', id: 'postgresqlPort', name: 'postgresqlPort', value: settings.postgresqlPort, suggestEnvVars: true, required: true, placeholder: '5432', errors: settings.getErrors('postgresqlPort'), inputAttributes: { 'data-craftsearch-target': 'db-port' } }) }}
    {{ forms.autosuggestField({ label: 'Database', id: 'postgresqlDatabase', name: 'postgresqlDatabase', value: settings.postgresqlDatabase, suggestEnvVars: true, required: true, placeholder: 'postgres', errors: settings.getErrors('postgresqlDatabase'), inputAttributes: { 'data-craftsearch-target': 'db-database' } }) }}
    {{ forms.autosuggestField({ label: 'User', id: 'postgresqlUser', name: 'postgresqlUser', value: settings.postgresqlUser, suggestEnvVars: true, required: true, placeholder: 'postgres', errors: settings.getErrors('postgresqlUser'), inputAttributes: { 'data-craftsearch-target': 'db-user' } }) }}
    {{ forms.autosuggestField({ label: 'Password', id: 'postgresqlPassword', name: 'postgresqlPassword', value: settings.postgresqlPassword, suggestEnvVars: true, required: true, placeholder: '$SUPABASE_DB_PASSWORD', errors: settings.getErrors('postgresqlPassword'), inputAttributes: { 'data-craftsearch-target': 'db-password' } }) }}
    {{ forms.textField({ label: 'Schema', id: 'vectorsSchemaName', name: 'vectorsSchemaName', value: settings.vectorsSchemaName, placeholder: 'public', errors: settings.getErrors('vectorsSchemaName') }) }}
    {{ forms.textField({ label: 'Vectors table', id: 'vectorsTableName', name: 'vectorsTableName', value: settings.vectorsTableName, required: true, errors: settings.getErrors('vectorsTableName') }) }}
    {{ forms.selectField({
        label: 'SSL mode', id: 'postgresqlSslMode', name: 'postgresqlSslMode', value: settings.postgresqlSslMode,
        options: [
            { label: 'Disable — localhost only', value: 'disable' },
            { label: 'Allow — localhost only', value: 'allow' },
            { label: 'Prefer — localhost only', value: 'prefer' },
            { label: 'Require (recommended)', value: 'require' },
            { label: 'Verify CA', value: 'verify-ca' },
            { label: 'Verify full', value: 'verify-full' },
        ],
        required: true, errors: settings.getErrors('postgresqlSslMode'),
        inputAttributes: { 'data-craftsearch-target': 'db-ssl-mode' },
    }) }}
{% endnamespace %}

<div class="buttons settings__db-test">
    <button type="button" class="btn disabled" data-craftsearch-control="test-db" disabled>Test connection</button>
    <span class="settings__test-result" data-craftsearch-target="test-db-result"></span>
</div>
