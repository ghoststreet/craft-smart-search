{% import '_includes/forms.twig' as forms %}

<h2 id="connection-postgres">PostgreSQL</h2>
<p class="light">Smart Search stores its vector index in a Postgres database with <code>pgvector</code>. Any Postgres 14 or later works. <a href="{{ wikiUrl }}/Installation#vectors-table" target="_blank" rel="noopener">Setup guide</a>.</p>

{% namespace 'settings' %}
    {{ forms.autosuggestField({ label: 'Host', instructions: 'Address of your Postgres server. Reference an env var like <code>$SUPABASE_DB_HOST</code> when possible.', id: 'postgresqlHost', name: 'postgresqlHost', value: settings.postgresqlHost, suggestEnvVars: true, required: true, placeholder: 'db.xxxx.supabase.co or $SUPABASE_DB_HOST', errors: settings.getErrors('postgresqlHost'), inputAttributes: { 'data-craftsearch-target': 'db-host' } }) }}
    {{ forms.autosuggestField({ label: 'Port', instructions: 'Default <code>5432</code>.', id: 'postgresqlPort', name: 'postgresqlPort', value: settings.postgresqlPort, suggestEnvVars: true, required: true, placeholder: '5432', errors: settings.getErrors('postgresqlPort'), inputAttributes: { 'data-craftsearch-target': 'db-port' } }) }}
    {{ forms.autosuggestField({ label: 'Database', instructions: 'Name of the database to use. Supabase and most providers default to <code>postgres</code>.', id: 'postgresqlDatabase', name: 'postgresqlDatabase', value: settings.postgresqlDatabase, suggestEnvVars: true, required: true, placeholder: 'postgres', errors: settings.getErrors('postgresqlDatabase'), inputAttributes: { 'data-craftsearch-target': 'db-database' } }) }}
    {{ forms.autosuggestField({ label: 'User', instructions: 'Database username. Needs permission to create tables in the schema below.', id: 'postgresqlUser', name: 'postgresqlUser', value: settings.postgresqlUser, suggestEnvVars: true, required: true, placeholder: 'postgres', errors: settings.getErrors('postgresqlUser'), inputAttributes: { 'data-craftsearch-target': 'db-user' } }) }}
    {{ forms.autosuggestField({ label: 'Password', instructions: 'Reference an env var like <code>$SUPABASE_DB_PASSWORD</code>. Never paste the raw value.', id: 'postgresqlPassword', name: 'postgresqlPassword', value: settings.postgresqlPassword, suggestEnvVars: true, required: true, placeholder: '$SUPABASE_DB_PASSWORD', errors: settings.getErrors('postgresqlPassword'), inputAttributes: { 'data-craftsearch-target': 'db-password' } }) }}
    {{ forms.selectField({
        label: 'Connection security (SSL mode)',
        instructions: 'Use <em>Require</em> for hosted databases. Only pick <em>Disable, Allow, Prefer</em> on a local dev database. Default <code>require</code>.',
        id: 'postgresqlSslMode', name: 'postgresqlSslMode', value: settings.postgresqlSslMode,
        options: [
            { label: 'Disable (local dev only)', value: 'disable' },
            { label: 'Allow (local dev only)', value: 'allow' },
            { label: 'Prefer (local dev only)', value: 'prefer' },
            { label: 'Require (recommended for hosted databases)', value: 'require' },
            { label: 'Verify CA (also checks the certificate authority)', value: 'verify-ca' },
            { label: 'Verify Full (strictest; also checks the hostname)', value: 'verify-full' },
        ],
        required: true, errors: settings.getErrors('postgresqlSslMode'),
        inputAttributes: { 'data-craftsearch-target': 'db-ssl-mode' },
    }) }}
{% endnamespace %}

<div class="buttons settings__db-test">
    <button type="button" class="btn disabled" data-craftsearch-control="test-db" disabled>Test connection</button>
    <span class="settings__test-result" data-craftsearch-target="test-db-result"></span>
</div>

{% namespace 'settings' %}
    {{ forms.textField({ label: 'Schema', instructions: 'Postgres schema that holds the vectors table. Default <code>public</code>.', id: 'vectorsSchemaName', name: 'vectorsSchemaName', value: settings.vectorsSchemaName, placeholder: 'public', errors: settings.getErrors('vectorsSchemaName'), inputAttributes: { 'data-craftsearch-target': 'db-vectors-schema' } }) }}
    {{ forms.textField({ label: 'Vectors table', instructions: 'Name of the table that holds your search vectors. You create it once via the install SQL; the plugin will not create it for you.', id: 'vectorsTableName', name: 'vectorsTableName', value: settings.vectorsTableName, required: true, placeholder: 'smart_search_vectors', errors: settings.getErrors('vectorsTableName'), inputAttributes: { 'data-craftsearch-target': 'db-vectors-table' } }) }}
    {% set trgmInstalled = craft.app.plugins.getPlugin('smart-search').dictionaryService.hasTrgmExtension() %}
    {{ forms.textField({
        label: 'Dictionary table',
        instructions: trgmInstalled
            ? 'Postgres table that holds the typo dictionary, in the same schema as the vectors table. Default <code>smart_search_terms</code>.'
            : 'Install the <code>pg_trgm</code> extension to configure this. See the Smart Search tab for steps.',
        id: 'termsTableName', name: 'termsTableName',
        value: settings.termsTableName,
        required: true, placeholder: 'smart_search_terms',
        disabled: not trgmInstalled,
        errors: settings.getErrors('termsTableName'),
    }) }}
    {{ forms.textField({
        label: 'Boosts table',
        instructions: 'Postgres table that holds per-entry boost rules, in the same schema as the vectors table. Created by the install SQL. Default <code>smart_search_boosts</code>.',
        id: 'boostsTableName', name: 'boostsTableName',
        value: settings.boostsTableName,
        required: true, placeholder: 'smart_search_boosts',
        errors: settings.getErrors('boostsTableName'),
    }) }}
{% endnamespace %}
