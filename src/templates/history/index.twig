{% extends "_layouts/cp" %}
{% import 'smart-search/_components/filter-fields' as f %}

{% set title = 'Search History' %}
{% set selectedSubnavItem = 'history' %}

{% set items = page.items %}
{% set totalPages = page.pages %}
{% set currentPage = page.page %}
{% set typeFilter = filters.type %}
{% set daysFilter = filters.days %}
{% set errorsOnly = filters.errorsOnly %}
{% set siteFilter = filters.siteId %}

{% block content %}
    <h2>Statistics{% if daysFilter %} (last {{ daysFilter }} days){% endif %}</h2>
    <table class="data fullwidth">
        <tbody>
            <tr>
                <th class="light">Total Searches</th>
                <td>{{ stats.searches|number_format }}</td>
                <th class="light">Total Tokens</th>
                <td>{{ stats.tokens|number_format }}</td>
            </tr>
            <tr>
                <th class="light">Total Cost</th>
                <td>${{ stats.cost|number_format(6) }}</td>
                <th class="light">Avg Cost / Search</th>
                <td>${{ stats.avgCostPerSearch|number_format(6) }}</td>
            </tr>
            <tr>
                <th class="light">Avg Duration</th>
                <td>{{ stats.avgDurationMs|number_format }} ms</td>
                <th class="light">Errors</th>
                <td>{{ stats.errorCount|number_format }}</td>
            </tr>
        </tbody>
    </table>

    {% if stats.byType is not empty %}
        <p class="light history-index__by-type">
            {% for type, t in stats.byType %}
                <strong>{{ type }}</strong>: {{ t.count }} searches · {{ t.tokens|number_format }} tokens · ${{ t.cost|number_format(6) }}{% if not loop.last %} &nbsp;·&nbsp; {% endif %}
            {% endfor %}
        </p>
    {% endif %}

    <hr>

    <form method="get" action="{{ cpUrl('smart-search/history') }}">
        <div class="filter-bar">
            {{ f.sitesSelect(sites, siteFilter) }}
            {{ f.typeSelect(typeFilter) }}
            {{ f.daysSelect(daysFilter) }}
            {{ f.errorsOnlyCheckbox(errorsOnly) }}
            {{ f.submitButton() }}
            {{ f.resetButton(cpUrl('smart-search/history'), typeFilter or daysFilter or errorsOnly or siteFilter) }}
        </div>
    </form>

    <h2>Searches ({{ page.total|number_format }})</h2>
    {% include 'smart-search/_partials/search-history-table' with {
        items: items,
        urlPath: 'smart-search/history',
    } only %}

    {% include 'smart-search/_components/pagination-cp' with {
        currentPage: currentPage,
        totalPages: totalPages,
        path: 'smart-search/history',
        baseParams: { type: typeFilter, days: daysFilter, errorsOnly: errorsOnly ? 1 : null, siteId: siteFilter },
    } only %}
{% endblock %}
