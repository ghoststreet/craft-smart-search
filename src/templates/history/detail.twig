{% extends "_layouts/cp" %}

{% set title = row.type|upper ~ ' Search' %}
{% set selectedSubnavItem = selectedSubnavItem ?? 'insights' %}

{% set embeddingCost = embeddingRates ? (row.embeddingTokens / 1000000) * embeddingRates.input : 0 %}
{% set ragInputCost = ragRates ? (row.ragInputTokens / 1000000) * ragRates.input : 0 %}
{% set ragOutputCost = ragRates ? (row.ragOutputTokens / 1000000) * ragRates.output : 0 %}

{% set isCleared = row.detailsId is null %}

{% set typeStatus = row.type == 'rag' ? 'live' : 'pending' %}
{% set confidenceColor = {high: 'green', medium: 'orange', low: 'red'}[row.confidence|default('medium')] %}

{% set fromInsights = selectedSubnavItem == 'insights' %}
{% set backUrl = fromInsights ? cpUrl('smart-search/insights', { tab: 'history' }) : cpUrl('smart-search/history') %}
{% set backLabel = fromInsights ? 'Back to History Log' : 'Back to Search History' %}

{% set crumbs = [
    { label: 'Smart Search', url: cpUrl('smart-search') },
    { label: fromInsights ? 'History Log' : 'Search History', url: backUrl },
] %}

{% set additionalButtons %}
    <a href="{{ backUrl }}" class="btn" data-icon="arrow-left">{{ backLabel }}</a>
{% endset %}

{% block content %}
<div class="history-detail">

    {# ── Header ── #}
    <div class="pane history-detail__pane">
        <div class="history-detail__header">
            <span class="status {{ typeStatus }}"></span>
            <h1>{{ row.type|upper }}</h1>

            {% if row.confidence %}
                <span class="confidence-chip confidence-chip--{{ confidenceColor }}">
                    {{ row.confidence }} confidence
                </span>
            {% endif %}

            {% if row.hasError %}
                <span class="confidence-chip confidence-chip--red"><span class="status off"></span> Error</span>
            {% endif %}

            {% if row.embeddingCached %}
                <span class="confidence-chip">cached embedding</span>
            {% endif %}

            <div class="history-detail__header-spacer"></div>

            <span class="light" title="{{ row.dateCreated }}">
                {{ row.dateCreated|date('M j, Y g:i:s A') }}
            </span>
        </div>

        <dl class="history-detail__meta-grid">
            <div>
                <dt>Request ID</dt>
                <dd><code>{{ row.requestId }}</code></dd>
            </div>
            <div>
                <dt>User</dt>
                <dd>{{ row.userId ? 'User #' ~ row.userId : 'Anonymous' }}</dd>
            </div>
            <div>
                <dt>Site</dt>
                <dd>{{ row.siteId ? 'Site #' ~ row.siteId : '—' }}</dd>
            </div>
            <div>
                <dt>Results</dt>
                <dd>{{ row.resultsCount }}</dd>
            </div>
        </dl>
    </div>

    {# ── Stat cards strip ── #}
    <div class="stat-strip">
        <div class="pane stat-strip__card">
            <div class="stat-strip__label">Duration</div>
            <div class="stat-strip__value">{{ row.durationMs|number_format }}<span class="stat-strip__unit">ms</span></div>
        </div>
        <div class="pane stat-strip__card">
            <div class="stat-strip__label">Total tokens</div>
            <div class="stat-strip__value">{{ row.totalTokens|number_format }}</div>
            <div class="stat-strip__sub light">
                {{ row.embeddingTokens|number_format }} emb · {{ row.ragInputTokens|number_format }} in · {{ row.ragOutputTokens|number_format }} out
            </div>
        </div>
        <div class="pane stat-strip__card">
            <div class="stat-strip__label">Total cost</div>
            <div class="stat-strip__value">${{ row.cost }}</div>
        </div>
        <div class="pane stat-strip__card">
            <div class="stat-strip__label">Models</div>
            <div class="stat-strip__value stat-strip__value--small">
                <div><span class="light">embed:</span> {{ row.embeddingModel ?? '—' }}</div>
                <div><span class="light">rag:</span> {{ row.ragModel ?? '—' }}</div>
            </div>
        </div>
    </div>

    <div class="history-detail__cols">

        {# ── Left: content ── #}
        <div class="history-detail__col-main">
            {% if isCleared %}
                <div class="pane">
                    <blockquote class="note">
                        <p>Result content for this search was removed by the retention policy.<br>
                        Token and cost statistics in the cards above are preserved.</p>
                    </blockquote>
                </div>
            {% else %}
                <div class="pane">
                    <h2>Query</h2>
                    <div class="history-detail__query">{{ row.query }}</div>
                </div>

                {% if row.errorMessage %}
                    <div class="pane">
                        <h2 class="error">Error</h2>
                        <pre class="history-detail__pre">{{ row.errorMessage }}</pre>
                    </div>
                {% endif %}

                {% if row.summary %}
                    <div class="pane">
                        <h2>Summary</h2>
                        <div class="readable history-detail__summary">{{ row.summary|md|raw }}</div>
                    </div>
                {% endif %}

                <div class="pane">
                    <h2>Results <span class="light">({{ row.resultsCount }})</span></h2>
                    {% if row.results %}
                        <table class="data fullwidth">
                            <thead>
                                <tr>
                                    <th class="thin">#</th>
                                    <th>Title</th>
                                    <th>URL</th>
                                    <th class="thin">Type</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for r in row.results %}
                                    <tr>
                                        <td class="thin light">{{ loop.index }}</td>
                                        <td>
                                            <strong>{{ r.title ?: (r.id ? '#' ~ r.id : '—') }}</strong>
                                        </td>
                                        <td>
                                            {% if r.url %}
                                                <a href="{{ r.url }}" target="_blank" rel="noopener" class="history-detail__url">{{ r.url }}</a>
                                            {% else %}—{% endif %}
                                        </td>
                                        <td class="thin"><code>{{ r.type ?? '—' }}</code></td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    {% else %}
                        <p class="light">No results.</p>
                    {% endif %}
                </div>

                {% if row.results %}
                    <div class="pane">
                        <details>
                            <summary><strong>Raw JSON</strong></summary>
                            <pre class="history-detail__pre history-detail__pre--json">{{ row.results|json_encode(constant('JSON_PRETTY_PRINT') b-or constant('JSON_UNESCAPED_SLASHES')) }}</pre>
                        </details>
                        <p class="light history-detail__trace">
                            Trace this request in the log:<br>
                            <code>tail -f storage/logs/smart-search.log | grep {{ row.requestId }}</code>
                        </p>
                    </div>
                {% endif %}
            {% endif %}
        </div>

        {# ── Right: token/cost breakdown ── #}
        <div class="history-detail__col-side">
            <div class="pane">
                <h2>Tokens</h2>
                <table class="data fullwidth kv-table">
                    <tbody>
                        <tr>
                            <th>Embedding</th>
                            <td class="rightalign">
                                {{ row.embeddingTokens|number_format }}
                                {% if row.embeddingCached %}<span class="light"> · cached</span>{% endif %}
                            </td>
                        </tr>
                        <tr>
                            <th>RAG input</th>
                            <td class="rightalign">{{ row.ragInputTokens|number_format }}</td>
                        </tr>
                        <tr>
                            <th>RAG output</th>
                            <td class="rightalign">{{ row.ragOutputTokens|number_format }}</td>
                        </tr>
                        <tr class="kv-table__total">
                            <th>Total</th>
                            <td class="rightalign">{{ row.totalTokens|number_format }}</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="pane">
                <h2>Cost</h2>
                <table class="data fullwidth kv-table">
                    <tbody>
                        <tr>
                            <th>
                                Embedding
                                {% if embeddingRates %}<span class="light">${{ embeddingRates.input }}/1M</span>{% endif %}
                            </th>
                            <td class="rightalign">${{ embeddingCost|number_format(6) }}</td>
                        </tr>
                        <tr>
                            <th>
                                RAG input
                                {% if ragRates %}<span class="light">${{ ragRates.input }}/1M</span>{% endif %}
                            </th>
                            <td class="rightalign">${{ ragInputCost|number_format(6) }}</td>
                        </tr>
                        <tr>
                            <th>
                                RAG output
                                {% if ragRates %}<span class="light">${{ ragRates.output }}/1M</span>{% endif %}
                            </th>
                            <td class="rightalign">${{ ragOutputCost|number_format(6) }}</td>
                        </tr>
                        <tr class="kv-table__total">
                            <th>Total</th>
                            <td class="rightalign">${{ row.cost }}</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
