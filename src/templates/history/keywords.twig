{% extends "_layouts/cp" %}
{% import 'smart-search/_components/filter-fields' as f %}

{% set title = 'Search Keywords' %}
{% set selectedSubnavItem = 'keywords' %}

{% set daysFilter = filters.days %}
{% set siteFilter = filters.siteId %}

{% block content %}
    <form method="get" action="{{ cpUrl('smart-search/history/keywords') }}">
        <div class="filter-bar">
            {{ f.sitesSelect(keywords.sites, siteFilter) }}
            {{ f.daysSelect(daysFilter) }}
            {{ f.submitButton() }}
        </div>
    </form>

    <p class="light history-keywords__lede">
        Keyword analytics are computed from stored search queries. Data is bounded by the plugin's <code>historyRetentionDays</code> setting.
    </p>

    <div class="history-keywords__grid">
        <div>
            <h2>Top keywords{% if daysFilter %} (last {{ daysFilter }} days){% endif %}</h2>
            <table class="data fullwidth">
                <thead>
                    <tr>
                        <th>Query</th>
                        <th class="rightalign">Hits</th>
                        <th class="rightalign">0-result</th>
                        <th>Last seen</th>
                    </tr>
                </thead>
                <tbody>
                    {% for k in keywords.top %}
                        <tr>
                            <td>{{ k.query|slice(0, 80) }}{% if k.query|length > 80 %}…{% endif %}</td>
                            <td class="rightalign">{{ k.hits|number_format }}</td>
                            <td class="rightalign">{% if k.zeroHits > 0 %}<span class="light">{{ k.zeroHits }}</span>{% else %}—{% endif %}</td>
                            <td><span class="light">{{ k.lastSeen|date('M j, g:ia') }}</span></td>
                        </tr>
                    {% else %}
                        <tr><td colspan="4" class="centeralign light">No keywords yet.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <div>
            <h2>No-results queries</h2>
            <table class="data fullwidth">
                <thead>
                    <tr>
                        <th>Query</th>
                        <th class="rightalign">Hits</th>
                        <th>Last seen</th>
                    </tr>
                </thead>
                <tbody>
                    {% for k in keywords.zeroResults %}
                        <tr>
                            <td>{{ k.query|slice(0, 80) }}{% if k.query|length > 80 %}…{% endif %}</td>
                            <td class="rightalign">{{ k.hits|number_format }}</td>
                            <td><span class="light">{{ k.lastSeen|date('M j, g:ia') }}</span></td>
                        </tr>
                    {% else %}
                        <tr><td colspan="3" class="centeralign light">All searches returned results.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <div>
            <h2>Trending (last 7 days)</h2>
            <table class="data fullwidth">
                <thead>
                    <tr>
                        <th>Query</th>
                        <th class="rightalign">Recent</th>
                        <th class="rightalign">Prior</th>
                        <th class="rightalign">Δ</th>
                    </tr>
                </thead>
                <tbody>
                    {% for k in keywords.trending %}
                        <tr>
                            <td>{{ k.query|slice(0, 80) }}{% if k.query|length > 80 %}…{% endif %}</td>
                            <td class="rightalign">{{ k.recent }}</td>
                            <td class="rightalign">{{ k.prior }}</td>
                            <td class="rightalign">
                                {% if k.growthPct is null %}
                                    <span class="status on" title="New keyword"></span> new
                                {% else %}
                                    +{{ k.growthPct }}%
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="4" class="centeralign light">Not enough data to spot trends.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
