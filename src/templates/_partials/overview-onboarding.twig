{#
    Onboarding checklist shown on the Overview tab when the plugin is not yet
    fully configured (credentials, schema, or OpenAI key missing).

    Params:
        setupSteps  list<{ done, label, hint, url }>  from IndexController::buildSetupSteps
#}
<h2>Finish setup</h2>
<p class="light">Each step links to where it can be fixed.</p>
<table class="data fullwidth collapsible">
    <tbody>
        {% for step in setupSteps %}
            <tr>
                <td class="thin centeralign">
                    {% if step.done %}<span class="success" data-icon="check"></span>
                    {% else %}<span class="error" data-icon="error"></span>{% endif %}
                </td>
                <td>
                    <a href="{{ step.url }}">{{ step.label }}</a>
                    {% if step.hint %}<div class="light smalltext">{{ step.hint }}</div>{% endif %}
                </td>
            </tr>
        {% endfor %}
    </tbody>
</table>
