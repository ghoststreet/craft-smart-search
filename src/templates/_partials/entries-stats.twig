{#
    Index status counts grid (Total / Indexed / Stale / Not indexed).
    Shared by debug/index.twig and index-mgmt/index.twig.

    Params:
        counts  object  { total, indexed, stale, 'not-indexed' }
        labels  object  { total, indexed, stale, notIndexed }
#}
{% set labels = labels ?? { total: 'Total', indexed: 'Indexed', stale: 'Stale', notIndexed: 'Not indexed', excluded: 'Excluded' } %}
<div class="index-stats">
    <div class="index-stats__item">
        <span class="index-stats__count">{{ counts.total }}</span>
        <span class="index-stats__label">{{ labels.total }}</span>
    </div>
    <div class="index-stats__item">
        <span class="status green"></span>
        <span class="index-stats__count">{{ counts.indexed }}</span>
        <span class="index-stats__label">{{ labels.indexed }}</span>
    </div>
    <div class="index-stats__item">
        <span class="status orange"></span>
        <span class="index-stats__count">{{ counts.stale }}</span>
        <span class="index-stats__label">{{ labels.stale }}</span>
    </div>
    <div class="index-stats__item">
        <span class="status off"></span>
        <span class="index-stats__count">{{ counts['not-indexed'] }}</span>
        <span class="index-stats__label">{{ labels.notIndexed }}</span>
    </div>
    <div class="index-stats__item">
        <span class="status grey"></span>
        <span class="index-stats__count">{{ counts.excluded ?? 0 }}</span>
        <span class="index-stats__label">{{ labels.excluded }}</span>
    </div>
</div>
