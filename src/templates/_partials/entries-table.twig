{#
    Indexable entries listing table. Used by index-mgmt/entries.twig.

    Params:
        rows  iterable
#}
{% if rows|length %}
    <div class="tableview data-table">
    <table class="data fullwidth big">
        <thead>
            <tr>
                <th scope="col">Title</th>
                <th scope="col">Section</th>
                <th scope="col" class="thin">Status</th>
                <th scope="col" class="thin">Chunks</th>
                <th scope="col" class="thin">Last indexed</th>
                <th scope="col" class="thin"><span class="visually-hidden">Actions</span></th>
            </tr>
        </thead>
        <tbody>
            {% for row in rows %}
                <tr data-craftsearch-entry-row data-element-id="{{ row.elementId }}" data-site-id="{{ row.siteId }}">
                    <td class="cell-bold">
                        <a href="{{ cpUrl('smart-search/index/entry', { elementId: row.elementId, siteId: row.siteId }) }}">{{ row.title ?: '(untitled)' }}</a>
                    </td>
                    <td>{{ row.section }}</td>
                    <td class="thin" data-craftsearch-target="status-cell">
                        {% if row.status == 'excluded' %}
                            <span class="status grey"></span> Excluded
                        {% elseif row.status == 'indexed' %}
                            <span class="status green"></span> Indexed
                        {% elseif row.status == 'stale' %}
                            <span class="status orange"></span> Stale
                        {% else %}
                            <span class="status off"></span> Not indexed
                        {% endif %}
                    </td>
                    <td class="thin" data-craftsearch-target="chunks-cell">{{ row.chunkCount }}</td>
                    <td class="thin" data-craftsearch-target="date-cell">
                        {% if row.lastIndexed %}
                            {{ row.lastIndexed|date('M j, Y g:i A') }}
                        {% else %}
                            <span class="light">—</span>
                        {% endif %}
                    </td>
                    <td class="thin centeralign">
                        {% for action in [
                            { name: 'reindex', label: 'Re-index',            icon: 'refresh',  hidden: row.excluded },
                            { name: 'exclude', label: 'Exclude from index',  icon: 'disabled', hidden: row.excluded },
                            { name: 'include', label: 'Re-include in index', icon: 'plus',     hidden: not row.excluded },
                        ] %}
                            <form method="post" data-craftsearch-control="{{ action.name }}-form" data-element-id="{{ row.elementId }}" data-site-id="{{ row.siteId }}"{% if action.hidden %} hidden{% endif %}>
                                {{ csrfInput() }}
                                {{ actionInput('smart-search/index/' ~ action.name ~ '-entry') }}
                                {{ redirectInput(craft.app.request.url) }}
                                <input type="hidden" name="elementId" value="{{ row.elementId }}">
                                <input type="hidden" name="siteId" value="{{ row.siteId }}">
                                <craft-tooltip placement="top" text="{{ action.label }}">
                                    <button type="submit" class="btn small" data-icon="{{ action.icon }}" aria-label="{{ action.label }}"></button>
                                </craft-tooltip>
                            </form>
                        {% endfor %}
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
    </div>
{% else %}
    <div class="zilch small">No entries match these filters.</div>
{% endif %}
