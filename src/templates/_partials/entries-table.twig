{#
    Indexable entries listing table. Used by index-mgmt/index.twig.

    Params:
        rows           iterable
        entryUrlPath   string   cpUrl path for the detail link, e.g. 'smart-search/index/entry'
        labels         object   { title, section, status, chunks, lastIndexed,
                                  indexed, stale, notIndexed, emptyMessage, untitled }
#}
{% set labels = labels ?? {} %}
{% set L = {
    title: 'Title', section: 'Section', status: 'Status',
    chunks: 'Chunks', lastIndexed: 'Last indexed',
    indexed: 'Indexed', stale: 'Stale', notIndexed: 'Not indexed',
    excluded: 'Excluded',
    emptyMessage: 'No entries match these filters.', untitled: '(untitled)',
}|merge(labels) %}

{% if rows|length %}
    <div class="tableview">
    <table class="data fullwidth big">
        <thead>
            <tr>
                <th scope="col">{{ L.title }}</th>
                <th scope="col">{{ L.section }}</th>
                <th scope="col" class="thin">{{ L.status }}</th>
                <th scope="col" class="thin">{{ L.chunks }}</th>
                <th scope="col" class="thin">{{ L.lastIndexed }}</th>
                <th scope="col" class="thin"><span class="visually-hidden">Actions</span></th>
            </tr>
        </thead>
        <tbody>
            {% for row in rows %}
                <tr data-craftsearch-entry-row data-element-id="{{ row.elementId }}" data-site-id="{{ row.siteId }}">
                    <td class="cell-bold">
                        <a href="{{ cpUrl(entryUrlPath, { elementId: row.elementId, siteId: row.siteId }) }}">{{ row.title ?: L.untitled }}</a>
                    </td>
                    <td>{{ row.section }}</td>
                    <td class="thin" data-craftsearch-status-cell>
                        {% if row.status == 'excluded' %}
                            <span class="status grey"></span> {{ L.excluded }}
                        {% elseif row.status == 'indexed' %}
                            <span class="status green"></span> {{ L.indexed }}
                        {% elseif row.status == 'stale' %}
                            <span class="status orange"></span> {{ L.stale }}
                        {% else %}
                            <span class="status off"></span> {{ L.notIndexed }}
                        {% endif %}
                    </td>
                    <td class="thin" data-craftsearch-chunks-cell>{{ row.chunkCount }}</td>
                    <td class="thin" data-craftsearch-date-cell>
                        {% if row.lastIndexed %}
                            {{ row.lastIndexed|date('M j, Y g:i A') }}
                        {% else %}
                            <span class="light">—</span>
                        {% endif %}
                    </td>
                    <td class="thin centeralign">
                        <form method="post" data-craftsearch-reindex="entry" data-element-id="{{ row.elementId }}" data-site-id="{{ row.siteId }}" style="display:{{ row.excluded ? 'none' : 'inline' }}">
                            {{ csrfInput() }}
                            {{ actionInput('smart-search/index/reindex-entry') }}
                            {{ redirectInput(craft.app.request.url) }}
                            <input type="hidden" name="elementId" value="{{ row.elementId }}">
                            <input type="hidden" name="siteId" value="{{ row.siteId }}">
                            <craft-tooltip placement="top" text="Re-index">
                                <button type="submit" class="btn small" data-icon="refresh" aria-label="Re-index"></button>
                            </craft-tooltip>
                        </form>
                        <form method="post" data-craftsearch-exclude="entry" data-element-id="{{ row.elementId }}" data-site-id="{{ row.siteId }}" style="display:{{ row.excluded ? 'none' : 'inline' }}">
                            {{ csrfInput() }}
                            {{ actionInput('smart-search/index/exclude-entry') }}
                            {{ redirectInput(craft.app.request.url) }}
                            <input type="hidden" name="elementId" value="{{ row.elementId }}">
                            <input type="hidden" name="siteId" value="{{ row.siteId }}">
                            <craft-tooltip placement="top" text="Exclude from index">
                                <button type="submit" class="btn small" data-icon="disabled" aria-label="Exclude from index"></button>
                            </craft-tooltip>
                        </form>
                        <form method="post" data-craftsearch-include="entry" data-element-id="{{ row.elementId }}" data-site-id="{{ row.siteId }}" style="display:{{ row.excluded ? 'inline' : 'none' }}">
                            {{ csrfInput() }}
                            {{ actionInput('smart-search/index/include-entry') }}
                            {{ redirectInput(craft.app.request.url) }}
                            <input type="hidden" name="elementId" value="{{ row.elementId }}">
                            <input type="hidden" name="siteId" value="{{ row.siteId }}">
                            <craft-tooltip placement="top" text="Re-include in index">
                                <button type="submit" class="btn small" data-icon="plus" aria-label="Re-include in index"></button>
                            </craft-tooltip>
                        </form>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
    </div>
{% else %}
    <div class="zilch small">{{ L.emptyMessage }}</div>
{% endif %}
