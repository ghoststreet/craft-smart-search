{#
    Filter toolbar for the indexable-entries listing.
    Used by index-mgmt/entries.twig.

    Params:
        filters   object  { siteId, section, status }
        sites     iterable
        sections  iterable
#}
{% import "_includes/forms.twig" as forms %}
{% import 'smart-search/_components/filter-fields' as f %}

<div class="filter-bar" data-craftsearch-target="filter-bar">
    <form method="get" action="{{ cpUrl('smart-search/index/entries') }}" class="filter-bar__form" data-craftsearch-target="filter-bar-form">
        <div class="filter-bar__group">
            {{ f.sitesSelect(sites, filters.siteId, false) }}

            {{ forms.selectField({
                label: 'Section',
                name: 'section',
                value: filters.section,
                options: [{ label: 'All sections', value: '' }]|merge(sections|map(s => { label: s.name, value: s.handle })),
            }) }}

            {{ forms.selectField({
                label: 'Status',
                name: 'status',
                value: filters.status,
                options: [
                    { label: 'All', value: '' },
                    { label: 'Indexed', value: 'indexed' },
                    { label: 'Stale', value: 'stale' },
                    { label: 'Not indexed', value: 'not-indexed' },
                    { label: 'Excluded', value: 'excluded' },
                ],
            }) }}

            <button type="submit" class="btn submit">Filter</button>
            {{ f.resetButton(
                cpUrl('smart-search/index/entries'),
                hasActiveFilters ?? (filters.section or filters.status)
            ) }}
        </div>
    </form>
</div>
