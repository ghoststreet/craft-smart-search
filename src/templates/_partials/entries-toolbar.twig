{#
    Filter toolbar for the indexable-entries listing.
    Used by index-mgmt/index.twig.

    Params:
        filters         object  { siteId, section, status }
        sites           iterable
        sections        iterable
        formClass       string  optional class on the <form>
        hiddenFields    object  optional hidden inputs, e.g. { tab: 'entries' }
        labels          object  { site, section, status, all, allSections, indexed,
                                  stale, notIndexed, filter }
#}
{% import "_includes/forms.twig" as forms %}
{% import 'smart-search/_components/filter-fields' as f %}

{% set labels = labels ?? {} %}
{% set L = {
    site: 'Site', section: 'Section', status: 'Status',
    all: 'All', allSections: 'All sections',
    indexed: 'Indexed', stale: 'Stale', notIndexed: 'Not indexed',
    excluded: 'Excluded',
    filter: 'Filter',
}|merge(labels) %}

{% set sectionOptions = [{ label: L.allSections, value: '' }] %}
{% for section in sections %}
    {% set sectionOptions = sectionOptions|merge([{ label: section.name, value: section.handle }]) %}
{% endfor %}

{% set statusOptions = [
    { label: L.all, value: '' },
    { label: L.indexed, value: 'indexed' },
    { label: L.stale, value: 'stale' },
    { label: L.notIndexed, value: 'not-indexed' },
    { label: L.excluded, value: 'excluded' },
] %}

<div class="filter-bar">
    <form method="get" action="" class="filter-bar__form{% if formClass is defined and formClass %} {{ formClass }}{% endif %}">
        {% for name, value in hiddenFields ?? {} %}
            <input type="hidden" name="{{ name }}" value="{{ value }}">
        {% endfor %}
        <div class="filter-bar__group">
            {{ f.sitesSelect(sites, filters.siteId, false) }}

            {{ forms.selectField({
                label: L.section,
                name: 'section',
                value: filters.section,
                options: sectionOptions,
            }) }}

            {{ forms.selectField({
                label: L.status,
                name: 'status',
                value: filters.status,
                options: statusOptions,
            }) }}

            <button type="submit" class="btn submit">{{ L.filter }}</button>
        </div>
    </form>
</div>
