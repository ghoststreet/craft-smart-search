{#
    7-column search history table (Query · Type · Results · Tokens · Cost · Duration · Date).
    Shared by history/index.twig and insights/index.twig (history tab).

    Params:
        items     iterable of history rows
        urlPath   string  cpUrl base, e.g. 'smart-search/history' or 'smart-search/insights'

    Usage:
        {% include 'smart-search/_partials/search-history-table' with {
            items: page.items, urlPath: 'smart-search/history'
        } only %}
#}
{% set cachedTitle = cachedTitle ?? 'Embedding served from cache' %}
{% if items|length %}
    <div class="tableview data-table data-table--auto">
        <table class="data fullwidth big">
            <thead>
                <tr>
                    <th scope="col">Query</th>
                    <th scope="col">Type</th>
                    <th scope="col" class="rightalign">Results</th>
                    <th scope="col" class="rightalign">Tokens</th>
                    <th scope="col" class="rightalign">Cost</th>
                    <th scope="col" class="rightalign">Duration</th>
                    <th scope="col">Date</th>
                </tr>
            </thead>
            <tbody>
                {% for item in items %}
                    {% set href = cpUrl(urlPath ~ '/' ~ item.id) %}
                    <tr>
                        <td>
                            {% if item.detailsId %}
                                <a href="{{ href }}">{{ item.query|slice(0, 120) }}{% if item.query|length > 120 %}…{% endif %}</a>
                            {% else %}
                                <span class="light">— cleared</span>
                            {% endif %}
                        </td>
                        <td>
                            <span class="status {% if item.type == 'rag' %}on{% else %}orange{% endif %}"></span>
                            {{ item.type }}
                            {% if item.hasError %}<span class="status red" title="Error"></span>{% endif %}
                        </td>
                        <td class="rightalign{% if item.resultsCount == 0 %} light{% endif %}">{{ item.resultsCount }}</td>
                        <td class="rightalign">{{ item.totalTokens|number_format }}{% if item.embeddingCached %} <span class="light" title="{{ cachedTitle }}">·c</span>{% endif %}</td>
                        <td class="rightalign">${{ item.cost|number_format(6) }}</td>
                        <td class="rightalign light">{{ item.durationMs|number_format }} ms</td>
                        <td><span class="light" title="{{ item.dateCreated|date('Y-m-d H:i:s') }}">{{ item.dateCreated|date('M j, Y') }}</span></td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% else %}
    {% include 'smart-search/_components/empty-state' with {
        variant: 'neutral',
        title: 'No searches recorded yet',
        text: 'Searches will appear here as visitors use search.',
    } only %}
{% endif %}
