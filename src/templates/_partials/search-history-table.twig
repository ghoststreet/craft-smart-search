{#
    Search history table (Query · Type · Status · Results · Tokens · Cost · Duration · Date).
    Shared by history/index.twig and insights/index.twig (history tab).

    Params:
        items     iterable of history rows
        urlPath   string  cpUrl base, e.g. 'smart-search/history' or 'smart-search/insights'

    Usage:
        {% include 'smart-search/_partials/search-history-table' with {
            items: page.items, urlPath: 'smart-search/history'
        } only %}
#}
{% import 'smart-search/_components/badge' as b %}
{% set cachedTitle = cachedTitle ?? 'Embedding served from cache — 0 embedding tokens billed' %}
{% if items|length %}
    <div class="tableview data-table data-table--auto">
        <table class="data fullwidth big">
            <thead>
                <tr>
                    <th scope="col">Query</th>
                    <th scope="col">Type</th>
                    <th scope="col">Status</th>
                    <th scope="col" class="rightalign">Results</th>
                    <th scope="col" class="rightalign">Tokens</th>
                    <th scope="col" class="rightalign">Cost</th>
                    <th scope="col" class="rightalign">Duration</th>
                    <th scope="col">Date</th>
                </tr>
            </thead>
            <tbody>
                {% for item in items %}
                    <tr>
                        <td>
                            {% if item.detailsId %}
                                {{ item.query|slice(0, 120) }}{% if item.query|length > 120 %}…{% endif %}
                            {% else %}
                                <span class="light">— cleared</span>
                            {% endif %}
                        </td>
                        <td>{{ b.badge(item.type, item.type) }}</td>
                        <td>
                            {% if item.hasError %}
                                <button type="button" class="badge badge--error ss-error-badge"
                                        data-error-modal data-error-message="{{ item.errorMessage }}"
                                        title="{{ item.errorMessage }}"><span class="badge__dot"></span>Error</button>
                            {% else %}
                                {{ b.badge('Success', 'success') }}
                            {% endif %}
                        </td>
                        <td class="rightalign{% if item.resultsCount == 0 %} light{% endif %}">{{ item.resultsCount }}</td>
                        <td class="rightalign">
                            {%- set ragTokens = item.ragInputTokens + item.ragOutputTokens -%}
                            {%- set hasEmbedding = item.embeddingCached or item.embeddingTokens > 0 -%}
                            <span class="ss-tokens">
                                {%- if ragTokens > 0 -%}
                                    <span class="ss-token-val" title="RAG tokens (LLM {{ item.ragInputTokens|number_format }} in / {{ item.ragOutputTokens|number_format }} out)">{{ ragTokens|number_format }}<span class="ss-token-dot ss-token-dot--rag"></span></span>
                                {%- endif -%}
                                {%- if ragTokens > 0 and hasEmbedding %} <span class="ss-tokens__sep">/</span> {% endif -%}
                                {%- if item.embeddingCached -%}
                                    <span title="{{ cachedTitle }}">{{ b.badge('Cached', 'cached') }}</span>
                                {%- elseif item.embeddingTokens > 0 -%}
                                    <span class="ss-token-val" title="Embedding tokens">{{ item.embeddingTokens|number_format }}<span class="ss-token-dot ss-token-dot--embedding"></span></span>
                                {%- endif -%}
                                {%- if ragTokens == 0 and not hasEmbedding -%}
                                    <span class="light">—</span>
                                {%- endif -%}
                            </span>
                        </td>
                        <td class="rightalign">{% if item.cost > 0 %}${{ item.cost|number_format(6) }}{% else %}<span class="light">—</span>{% endif %}</td>
                        <td class="rightalign light">{{ item.durationMs|number_format }} ms</td>
                        <td><span class="light" title="{{ item.dateCreated|date('Y-m-d H:i:s') }}">{{ item.dateCreated|date('M j, Y') }}</span></td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% else %}
    {% include 'smart-search/_components/empty-state' with {
        variant: 'neutral',
        title: 'No searches recorded yet',
        text: 'Searches will appear here as visitors use search.',
    } only %}
{% endif %}
