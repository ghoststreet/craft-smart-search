{#
    Search history table (Query · Type · Status · Results · Tokens · Cost · Duration · Date).
    Used by insights/index.twig (history tab).

    Params:
        items  iterable of history rows
#}
{% import 'smart-search/_components/badge' as b %}
{% if items|length %}
    <div class="tableview ss-data-table ss-data-table--auto">
        <table class="data fullwidth big">
            <thead>
                <tr>
                    <th scope="col">Query</th>
                    <th scope="col">Type</th>
                    <th scope="col">Status</th>
                    <th scope="col" class="rightalign">Results</th>
                    <th scope="col" class="rightalign">Tokens</th>
                    <th scope="col" class="rightalign">Cost</th>
                    <th scope="col" class="rightalign">Duration</th>
                    <th scope="col">Date</th>
                </tr>
            </thead>
            <tbody>
                {% for item in items %}
                    <tr>
                        <td>{{ item.query|truncate(120) }}</td>
                        <td>{{ b.badge(item.type, item.type) }}</td>
                        <td>
                            {% if item.hasError %}
                                {{ b.errorBadge(item.errorMessage) }}
                            {% else %}
                                {{ b.badge('Success', 'success') }}
                            {% endif %}
                        </td>
                        <td class="rightalign{% if item.resultsCount == 0 %} light{% endif %}">{{ item.resultsCount }}</td>
                        <td class="rightalign">
                            {%- set aiAnswerTokens = item.aiAnswerInputTokens + item.aiAnswerOutputTokens -%}
                            {%- set hasEmbedding = item.embeddingCached or item.embeddingTokens > 0 -%}
                            <span class="ss-tokens">
                                {%- if aiAnswerTokens > 0 -%}
                                    <span class="ss-token-val" title="AI Answer tokens (LLM {{ item.aiAnswerInputTokens|number_format }} in / {{ item.aiAnswerOutputTokens|number_format }} out)">{{ aiAnswerTokens|number_format }}<span class="ss-token-dot ss-token-dot--ai-answer"></span></span>
                                {%- endif -%}
                                {%- if aiAnswerTokens > 0 and hasEmbedding %} <span class="ss-tokens__sep">/</span> {% endif -%}
                                {%- if item.embeddingCached -%}
                                    <span title="Embedding served from cache — 0 embedding tokens billed">{{ b.badge('Cached', 'cached') }}</span>
                                {%- elseif item.embeddingTokens > 0 -%}
                                    <span class="ss-token-val" title="Embedding tokens">{{ item.embeddingTokens|number_format }}<span class="ss-token-dot ss-token-dot--embedding"></span></span>
                                {%- endif -%}
                                {%- if aiAnswerTokens == 0 and not hasEmbedding -%}
                                    <span class="light">—</span>
                                {%- endif -%}
                            </span>
                        </td>
                        <td class="rightalign">{% if item.cost > 0 %}${{ item.cost|number_format(6) }}{% else %}<span class="light">—</span>{% endif %}</td>
                        <td class="rightalign light">{{ item.durationMs|number_format }} ms</td>
                        <td><span class="light" title="{{ item.dateCreated|date('Y-m-d H:i:s') }}">{{ item.dateCreated|date('M j, Y') }}</span></td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% else %}
    {% include 'smart-search/_components/empty-state' with {
        variant: 'neutral',
        title: 'No searches recorded yet',
        text: 'Searches will appear here as visitors use search.',
    } only %}
{% endif %}
