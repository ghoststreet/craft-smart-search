{#
    Pagination nav using cpUrl + baseParams|merge({page: n}).
    Used by the Insights pages that page through searches.

    Params:
        currentPage  int    current page number
        totalPages   int    total number of pages
        path         string cpUrl path (e.g. 'smart-search/insights')
        baseParams   object query params to preserve across pages
        navClass     string optional extra class on the <nav>

    Usage:
        {% include 'smart-search/_components/pagination-cp' with {
            currentPage: page.page, totalPages: page.pages,
            path: 'smart-search/insights',
            baseParams: { type: typeFilter, days: daysFilter, ... }
        } only %}
#}
{% if totalPages > 1 %}
    <nav class="pagination-nav{% if navClass ?? false %} {{ navClass }}{% endif %}">
        {% if currentPage > 1 %}<a class="btn" href="{{ cpUrl(path, baseParams|merge({ page: currentPage - 1 })) }}">‹ Prev</a>{% endif %}
        <span class="light pagination-nav__label">Page {{ currentPage }} of {{ totalPages }}</span>
        {% if currentPage < totalPages %}<a class="btn" href="{{ cpUrl(path, baseParams|merge({ page: currentPage + 1 })) }}">Next ›</a>{% endif %}
    </nav>
{% endif %}
