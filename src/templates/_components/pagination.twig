{#
    Pagination nav. Renders nothing for a single page.

    Params:
        currentPage  int    current page number
        totalPages   int    total number of pages
        path         string cpUrl path (e.g. 'smart-search/insights')
        params       object query params to preserve across pages

    Usage:
        {% include 'smart-search/_components/pagination' with {
            currentPage: page.page, totalPages: page.pages,
            path: 'smart-search/insights',
            params: { type: typeFilter, days: daysFilter },
        } only %}
#}
{% if totalPages > 1 %}
    <nav class="pagination-nav">
        {% if currentPage > 1 %}<a class="btn" href="{{ cpUrl(path, params|merge({ page: currentPage - 1 })) }}">‹ Prev</a>{% endif %}
        <span class="light pagination-nav__label">Page {{ currentPage }} of {{ totalPages }}</span>
        {% if currentPage < totalPages %}<a class="btn" href="{{ cpUrl(path, params|merge({ page: currentPage + 1 })) }}">Next ›</a>{% endif %}
    </nav>
{% endif %}
