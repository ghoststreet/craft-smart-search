{#
    Pill badge with a status dot and an uppercase label.

    Usage:
        {% import 'smart-search/_components/badge' as b %}
        {{ b.badge('rag', 'rag') }}
        {{ b.badge('Error', 'error') }}

    Params:
        label    string  text shown (uppercased via CSS)
        variant  string  rag | semantic | error
#}
{% macro badge(label, variant) %}
    <span class="badge badge--{{ variant }}"><span class="badge__dot"></span>{{ label }}</span>
{% endmacro %}
