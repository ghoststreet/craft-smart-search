{#
    Filter field macros — small reusable form atoms used by the various
    search/keyword/insights filter toolbars across the plugin. Delegates to
    Craft's native _includes/forms macros so the controls match CP styling.

    Usage:
        {% import 'smart-search/_components/filter-fields' as filters %}
        {{ filters.daysSelect(daysFilter) }}
        {{ filters.sitesSelect(sites, siteFilter) }}
        {{ filters.typeSelect(typeFilter) }}
        {{ filters.errorsOnlyCheckbox(errorsOnly) }}
#}
{% macro daysSelect(daysFilter) %}
    {% import "_includes/forms.twig" as forms %}
    {{ forms.selectField({
        label: 'Time range',
        name: 'days',
        value: daysFilter,
        options: [
            { label: 'All time', value: '' },
            { label: 'Last 24 hours', value: 1 },
            { label: 'Last 7 days', value: 7 },
            { label: 'Last 30 days', value: 30 },
            { label: 'Last 90 days', value: 90 },
        ],
    }) }}
{% endmacro %}

{% macro sitesSelect(sites, siteFilter, includeAll) %}
    {% import "_includes/forms.twig" as forms %}
    {% if sites|length > 1 %}
        {% set options = (includeAll ?? true) ? [{ label: 'All sites', value: '' }] : [] %}
        {% for s in sites %}
            {% set options = options|merge([{ label: s.name ?: s.handle, value: s.id }]) %}
        {% endfor %}
        {{ forms.selectField({
            label: 'Site',
            name: 'siteId',
            value: siteFilter,
            options: options,
        }) }}
    {% else %}
        <input type="hidden" name="siteId" value="{{ siteFilter }}">
    {% endif %}
{% endmacro %}

{% macro typeSelect(typeFilter) %}
    {% import "_includes/forms.twig" as forms %}
    {{ forms.selectField({
        label: 'Type',
        name: 'type',
        value: typeFilter,
        options: [
            { label: 'All', value: '' },
            { label: 'Smart', value: 'smart' },
            { label: 'AI Answer', value: 'aiAnswer' },
        ],
    }) }}
{% endmacro %}

{% macro errorsOnlyCheckbox(errorsOnly) %}
    {% import "_includes/forms.twig" as forms %}
    {{ forms.checkboxField({
        label: 'Errors only',
        name: 'errorsOnly',
        value: 1,
        checked: errorsOnly,
    }) }}
{% endmacro %}

{#
    Reset link — clears every filter by navigating to the unfiltered URL.
    Starts hidden unless a filter is already applied; the filter-bar JS
    component shows/hides it live as controls change.
#}
{% macro resetButton(url, active) %}
    <a href="{{ url }}" class="btn filter-bar__reset" data-craftsearch-target="filter-bar-reset"{% if not active %} hidden{% endif %}>Reset</a>
{% endmacro %}
