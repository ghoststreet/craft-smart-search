{#
    Filter field macros — small reusable form atoms used by the various
    search/keyword/insights filter toolbars across the plugin. Delegates to
    Craft's native _includes/forms macros so the controls match CP styling.

    Usage:
        {% import 'ai-search/_components/filter-fields' as filters %}
        {{ filters.daysSelect(daysFilter) }}
        {{ filters.sitesSelect(sites, siteFilter) }}
        {{ filters.typeSelect(typeFilter) }}
        {{ filters.errorsOnlyCheckbox(errorsOnly) }}
        {{ filters.submitButton() }}
#}
{% import "_includes/forms.twig" as forms %}

{% macro daysSelect(daysFilter, label) %}
    {% import "_includes/forms.twig" as forms %}
    {{ forms.selectField({
        label: label ?? 'Time range',
        name: 'days',
        value: daysFilter,
        options: [
            { label: 'All time', value: '' },
            { label: 'Last 24 hours', value: 1 },
            { label: 'Last 7 days', value: 7 },
            { label: 'Last 30 days', value: 30 },
            { label: 'Last 90 days', value: 90 },
        ],
    }) }}
{% endmacro %}

{% macro sitesSelect(sites, siteFilter) %}
    {% import "_includes/forms.twig" as forms %}
    {% if sites is not empty %}
        {% set options = [{ label: 'All sites', value: '' }] %}
        {% for s in sites %}
            {% set options = options|merge([{ label: s.name, value: s.id }]) %}
        {% endfor %}
        {{ forms.selectField({
            label: 'Site',
            name: 'siteId',
            value: siteFilter,
            options: options,
        }) }}
    {% endif %}
{% endmacro %}

{% macro typeSelect(typeFilter) %}
    {% import "_includes/forms.twig" as forms %}
    {{ forms.selectField({
        label: 'Type',
        name: 'type',
        value: typeFilter,
        options: [
            { label: 'All', value: '' },
            { label: 'Semantic', value: 'semantic' },
            { label: 'RAG', value: 'rag' },
        ],
    }) }}
{% endmacro %}

{% macro errorsOnlyCheckbox(errorsOnly, inline) %}
    {% import "_includes/forms.twig" as forms %}
    {{ forms.checkboxField({
        label: 'Errors only',
        name: 'errorsOnly',
        value: 1,
        checked: errorsOnly,
    }) }}
{% endmacro %}

{% macro submitButton(label) %}
    <button type="submit" class="btn submit">{{ label ?? 'Filter' }}</button>
{% endmacro %}
