{% set pageKey = 'entries' %}

{% extends 'smart-search/index-mgmt/_layout' %}

{% block content %}
    {% include 'smart-search/_partials/entries-toolbar' with {
        filters: filters,
        sites: sites,
        sections: sections,
        hasActiveFilters: hasActiveFilters,
    } only %}

    {% if error %}
        <blockquote class="note warning"><p><strong>Database error.</strong> {{ error }}</p></blockquote>
    {% endif %}

    {% include 'smart-search/_partials/entries-stats' with { counts: result.counts } only %}

    {% include 'smart-search/_partials/entries-table' with { rows: result.rows } only %}

    {% include 'smart-search/_components/pagination' with {
        currentPage: result.page,
        totalPages: (result.total / result.pageSize)|round(0, 'ceil'),
        params: filters,
        path: 'smart-search/index/entries',
    } only %}
{% endblock %}
