{% extends "_layouts/cp" %}

{% set title = 'Index' %}
{% set selectedSubnavItem = 'index' %}

{% set tabs = {
    overview: { label: 'Overview & sync',   url: cpUrl('smart-search/index', { tab: 'overview' }) },
    entries:  { label: 'Entries',           url: cpUrl('smart-search/index', { tab: 'entries' }) },
    coverage: { label: 'Per-site coverage', url: cpUrl('smart-search/index', { tab: 'coverage' }) },
} %}
{% set selectedTab = tab %}

{% block content %}
    {% if tab == 'overview' %}
        <div class="craftsearch-overview" data-craftsearch-target="overview-region">
            <div class="craftsearch-overview__content" data-craftsearch-target="overview-content">
                <div class="craftsearch-entries__loading"><div class="spinner"></div></div>
            </div>
        </div>

    {% elseif tab == 'entries' %}
        <div class="craftsearch-entries" data-craftsearch-target="entries-region">
            {% include 'smart-search/_partials/entries-toolbar' with {
                filters: filters,
                sites: sites,
                sections: sections,
                hiddenFields: { tab: 'entries' },
                hasActiveFilters: hasActiveFilters,
            } only %}

            <div class="craftsearch-entries__content" data-craftsearch-target="entries-content">
                <div class="craftsearch-entries__loading" data-craftsearch-target="entries-loading">
                    <div class="spinner"></div>
                </div>
            </div>
        </div>

    {% elseif tab == 'coverage' %}
        <div class="craftsearch-coverage" data-craftsearch-target="coverage-region">
            <div class="craftsearch-coverage__content" data-craftsearch-target="coverage-content">
                <div class="craftsearch-entries__loading"><div class="spinner"></div></div>
            </div>
        </div>
    {% endif %}
{% endblock %}

