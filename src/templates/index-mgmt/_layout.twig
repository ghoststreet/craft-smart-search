{% extends "_layouts/cp" %}

{% set title = 'Index' %}
{% set selectedSubnavItem = 'index' %}

{% set tabs = {
    overview: { label: 'Overview & sync', url: cpUrl('smart-search/index') },
    entries:  { label: 'Entries',         url: cpUrl('smart-search/index/entries') },
} %}
