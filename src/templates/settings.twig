{% extends "_layouts/cp" %}

{% set title = 'Settings' %}
{% set fullPageForm = true %}
{% set wikiUrl = 'https://github.com/ghoststreet/craft-smart-search/wiki' %}

{% set tabs = {
    'tab-connections':   { label: 'Connections',   url: '#tab-connections',   class: settings.errorsForTab('tab-connections')   ? 'error' : '' },
    'tab-indexing':      { label: 'Indexing',      url: '#tab-indexing',      class: settings.errorsForTab('tab-indexing')      ? 'error' : '' },
    'tab-smart-search': { label: 'Smart Search', url: '#tab-smart-search', class: settings.errorsForTab('tab-smart-search') ? 'error' : '' },
    'tab-ai-answer':    { label: 'AI Answer',    url: '#tab-ai-answer',    class: settings.errorsForTab('tab-ai-answer')    ? 'error' : '' },
    'tab-advanced':    { label: 'Advanced',     url: '#tab-advanced',    class: settings.errorsForTab('tab-advanced')    ? 'error' : '' },
} %}

{% block content %}
    {{ actionInput('smart-search/settings/save') }}
    {{ redirectInput('smart-search/settings') }}

    <div id="tab-connections">
        {% include 'smart-search/_settings/_connections' %}
    </div>

    <div id="tab-indexing" class="hidden">
        {% include 'smart-search/_settings/_indexing' %}
    </div>

    <div id="tab-smart-search" class="hidden">
        {% include 'smart-search/_settings/_smart_search' %}
    </div>

    <div id="tab-ai-answer" class="hidden">
        {% include 'smart-search/_settings/_ai_answer' %}
    </div>

    <div id="tab-advanced" class="hidden">
        {% include 'smart-search/_settings/_advanced' %}
    </div>
{% endblock %}

